{
  "app": {
    "app_name": "amvision worker",
    "app_version": "0.1.0"
  },
  "workspace": {
    "root_dir": "./data/worker"
  },
  "database": {
    "url": "sqlite:///./data/amvision.db",
    "echo": false
  },
  "dataset_storage": {
    "root_dir": "./data/files"
  },
  "queue": {
    "root_dir": "./data/queue",
    "max_concurrent_tasks": 2,
    "poll_interval_seconds": 1.0
  }
}