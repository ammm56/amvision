{
  "app": {
    "app_name": "amvision worker",
    "app_version": "0.1.3"
  },
  "workspace": {
    "root_dir": "./data/worker"
  },
  "database": {
    "url": "sqlite:///./data/amvision.db",
    "echo": false
  },
  "dataset_storage": {
    "root_dir": "./data/files",
    "max_import_package_bytes": 21474836480,
    "max_import_extracted_bytes": 214748364800,
    "max_import_member_count": 2000000,
    "max_import_compression_ratio": 1000.0
  },
  "queue": {
    "root_dir": "./data/queue",
    "lease_timeout_seconds": 86400.0,
    "completed_retention_seconds": 86400.0,
    "failed_retention_seconds": 604800.0,
    "response_queue_retention_seconds": 3600.0
  },
  "task_manager": {
    "enabled_consumer_kinds": [
      "dataset-import",
      "dataset-export",
      "yolox-training",
      "yolov8-training",
      "yolo11-training",
      "yolo26-training",
      "yolox-conversion",
      "yolov8-conversion",
      "yolo11-conversion",
      "yolo26-conversion",
      "classification-evaluation",
      "segmentation-evaluation",
      "detection-evaluation",
      "pose-evaluation",
      "obb-evaluation",
      "rfdetr-training",
      "rfdetr-conversion",
      "detection-inference",
      "classification-inference",
      "segmentation-inference",
      "pose-inference",
      "obb-inference",
      "classification-training",
      "segmentation-training",
      "pose-training",
      "obb-training"
    ],
    "max_concurrent_tasks": 16,
    "poll_interval_seconds": 1.0
  },
  "async_inference_gateway_request_timeout_seconds": 30.0
}
