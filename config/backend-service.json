{
  "app": {
    "app_name": "amvision backend-service",
    "app_version": "0.1.0"
  },
  "database": {
    "url": "sqlite:///./data/amvision.db",
    "echo": false
  },
  "dataset_storage": {
    "root_dir": "./data/files"
  },
  "queue": {
    "root_dir": "./data/queue"
  },
  "task_manager": {
    "enabled": true,
    "max_concurrent_tasks": 2,
    "poll_interval_seconds": 1.0
  }
}