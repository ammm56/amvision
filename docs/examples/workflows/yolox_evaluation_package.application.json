{
  "format_id": "amvision.flow-application.v1",
  "application_id": "yolox-evaluation-package-app",
  "display_name": "YOLOX Evaluation Package App",
  "description": "正式 evaluation package app 示例：submit 不生成默认 result-package，wait 到终态后再由独立 package 节点输出一个临时 zip，并显式开启 cleanup_on_completion。",
  "template_ref": {
    "template_id": "yolox-evaluation-package-template",
    "template_version": "1.0.0",
    "source_kind": "json-file",
    "source_uri": "docs/examples/workflows/yolox_evaluation_package.template.json"
  },
  "runtime_mode": "python-json-workflow",
  "bindings": [
    {
      "binding_id": "request_payload",
      "direction": "input",
      "template_port_id": "request_payload",
      "binding_kind": "workflow-execute-input",
      "config": {
        "payload_type_id": "value.v1",
        "content_type": "application/json"
      },
      "metadata": {}
    },
    {
      "binding_id": "submission_body",
      "direction": "output",
      "template_port_id": "submission_body",
      "binding_kind": "workflow-execute-output",
      "config": {
        "payload_type_id": "response-body.v1"
      },
      "metadata": {}
    },
    {
      "binding_id": "evaluation_task_detail",
      "direction": "output",
      "template_port_id": "evaluation_task_detail",
      "binding_kind": "workflow-execute-output",
      "config": {
        "payload_type_id": "response-body.v1"
      },
      "metadata": {}
    },
    {
      "binding_id": "package_body",
      "direction": "output",
      "template_port_id": "package_body",
      "binding_kind": "workflow-execute-output",
      "config": {
        "payload_type_id": "response-body.v1"
      },
      "metadata": {}
    }
  ],
  "metadata": {
    "example_kind": "yolox-evaluation-package",
    "cleanup_mode": "explicit-node-parameter",
    "package_cleanup_policy": "delete_on_completion",
    "intended_saved_object_key": "workflows/projects/{project_id}/applications/yolox-evaluation-package-app/application.json"
  }
}