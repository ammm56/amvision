  "metadata": {
    "example_kind": "industrial-local-directory-batch-regions-continuity-gate",
    "focus": "local-batch-industrial-regions-rule-chain",
    "dynamic_batch_start_binding": "request_batch_start_index",
    "dynamic_batch_size_binding": "request_batch_size",
