{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-local-directory-batch-regions-continuity-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Local Directory Batch Regions Continuity Gate",
  "description": "面向工业现场本地目录批处理的 regions.v1 到规则闭环样例。输入目录路径、可选批次窗口、批次 cursor，以及按当前批次顺序对齐的 regions.v1 数组；逐图恢复标准 regions，再执行面积占比、连续性和断裂规则，并把单图结果持续追加到 CSV，最后输出批次 JSON 汇总。",
  "nodes": [
    {
      "node_id": "iterate_batch_start",
      "node_type_id": "core.logic.for-each-start",
      "parameters": {}
    },
    {
      "node_id": "request_directory_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "scan_directory",
      "node_type_id": "core.io.directory-scan",
      "parameters": {
        "recursive": false,
        "include_hidden": false,
        "extensions": [
          "png",
          "jpg",
          "jpeg",
          "bmp"
        ],
        "sort_by": "modified_time",
        "descending": true,
        "limit": 128,
        "min_stable_age_seconds": 1.0
      }
    },
    {
      "node_id": "batch_window",
      "node_type_id": "core.io.directory-batch-window",
      "parameters": {
        "start_index": 0,
        "batch_size": 8
      }
    },
    {
      "node_id": "iterate_batch",
      "node_type_id": "core.logic.for-each-end",
      "parameters": {}
    },
    {
      "node_id": "extract_current_file_path",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "path"
      }
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "get_current_regions_value",
      "node_type_id": "core.logic.list-item-get",
      "parameters": {}
    },
    {
      "node_id": "value_to_regions",
      "node_type_id": "core.logic.value-to-regions",
      "parameters": {}
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "class_names": [
          "sealant"
        ],
        "min_score": 0.6
      }
    },
    {
      "node_id": "area_ratio",
      "node_type_id": "core.vision.regions-area-ratio",
      "parameters": {}
    },
    {
      "node_id": "continuity_score",
      "node_type_id": "core.vision.region-continuity-score",
      "parameters": {}
    },
    {
      "node_id": "gap_check",
      "node_type_id": "core.vision.region-gap-check",
      "parameters": {
        "match_mode": "all",
        "max_component_count": 1,
        "max_hole_count": 0,
        "min_largest_component_ratio": 0.75
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "area_ratio_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "min_value": 0.02,
        "max_value": 0.18,
        "min_inclusive": true,
        "max_inclusive": true
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "file_record",
          "file_index"
        ],
        "fields": {
          "inspection_kind": "regions-continuity-gate-batch",
          "station_id": "line-seg-01"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "bridge_summary",
          "area_ratio",
          "filter_summary",
          "continuity_breakdown",
          "gap_metrics"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "area_ratio",
          "continuity"
        ],
        "ok_reason": "batch regions continuity gate passed",
        "ng_reason": "batch regions continuity gate failed"
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-batch-regions-continuity-gate/history.csv"
      }
    },
    {
      "node_id": "batch_summary_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "directory_path",
          "scan_summary",
          "window_summary",
          "window_cursor",
          "batch_files",
          "inspection_results",
          "inspection_result_count"
        ],
        "fields": {
          "example_kind": "industrial-local-directory-batch-regions-continuity-gate",
          "inspection_kind": "regions-continuity-gate-batch",
          "input_payload_mode": "request_regions_items.value[i] == regions.v1 of batch_files[i]",
          "archive_root": "workflow_app_result_dir",
          "json_archive_pattern": "industrial-local-directory-batch-regions-continuity-gate/result-{timestamp}.json",
          "csv_archive_relative_path": "industrial-local-directory-batch-regions-continuity-gate/history.csv"
        }
      }
    },
    {
      "node_id": "save_batch_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-batch-regions-continuity-gate/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    }
  ],
