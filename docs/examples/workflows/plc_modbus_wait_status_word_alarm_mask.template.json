{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "plc-modbus-wait-status-word-alarm-mask-template",
  "template_version": "1.0.0",
  "display_name": "PLC Modbus Wait Status Word Alarm Mask",
  "description": "面向工业现场报警状态字观察的 Modbus TCP wait-condition 样例。输入运行时连接与点位配置，持续轮询状态字，直到任一报警位命中后输出结果，并把现场归档写到本地 JSON。",
  "nodes": [
    {
      "node_id": "request_wait_config_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "wait_status_word_alarm",
      "node_type_id": "custom.plc.modbus.wait-condition",
      "parameters": {
        "host": "127.0.0.1",
        "port": 502,
        "unit_id": 1,
        "timeout_seconds": 1.0,
        "register_address": "400121",
        "data_type": "uint16",
        "operator": "bitmask_any_set",
        "expected_value": 48,
        "poll_interval_ms": 100,
        "wait_timeout_seconds": null,
        "stable_match_count": 1
      }
    },
    {
      "node_id": "archive_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "wait_config",
          "wait_result"
        ],
        "fields": {
          "example_kind": "plc-modbus-wait-status-word-alarm-mask",
          "description": "wait until any alarm bit is set",
          "default_mask_decimal": 48,
          "default_mask_hex": "0x0030"
        }
      }
    },
    {
      "node_id": "save_archive_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/plc-modbus-wait-status-word-alarm-mask/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-wait-config",
      "source_node_id": "request_wait_config_input",
      "source_port": "value",
      "target_node_id": "wait_status_word_alarm",
      "target_port": "request"
    },
    {
      "edge_id": "edge-request-archive",
      "source_node_id": "request_wait_config_input",
      "source_port": "value",
      "target_node_id": "archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-wait-result-archive",
      "source_node_id": "wait_status_word_alarm",
      "source_port": "result",
      "target_node_id": "archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-archive-save",
      "source_node_id": "archive_object",
      "source_port": "value",
      "target_node_id": "save_archive_json",
      "target_port": "value"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_wait_config",
      "display_name": "Request Wait Config",
      "payload_type_id": "value.v1",
      "target_node_id": "request_wait_config_input",
      "target_port": "payload"
    }
  ],
  "template_outputs": [
    {
      "output_id": "wait_result",
      "display_name": "Wait Result",
      "payload_type_id": "value.v1",
      "source_node_id": "wait_status_word_alarm",
      "source_port": "result"
    },
    {
      "output_id": "archive",
      "display_name": "Archive",
      "payload_type_id": "value.v1",
      "source_node_id": "archive_object",
      "source_port": "value"
    },
    {
      "output_id": "json_summary",
      "display_name": "JSON Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_archive_json",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "plc-modbus-wait-status-word-alarm-mask",
    "focus": "plc-modbus-wait-status-word-mask",
    "mask_operator": "bitmask_any_set",
    "default_mask_decimal": 48,
    "default_mask_hex": "0x0030",
    "node_groups": {
      "input": [
        "request_wait_config_input"
      ],
      "wait": [
        "wait_status_word_alarm"
      ],
      "archive": [
        "archive_object",
        "save_archive_json"
      ]
    }
  }
}
