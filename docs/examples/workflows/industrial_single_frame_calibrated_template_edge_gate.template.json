{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-calibrated-template-edge-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Calibrated Template Edge Gate",
  "description": "面向工业单帧现场的本地标定定位样例。输入本地图像路径、模板图路径、本地畸变 JSON 路径和本地 remap JSON 路径；先执行 undistort/remap，再并联执行 template-match 与 caliper-edge，最后收成 OK/NG、报警对象和本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_template_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_undistort_config_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_remap_mapping_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_template_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_undistort_config",
      "node_type_id": "core.io.json-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_remap_mapping",
      "node_type_id": "core.io.json-load-local",
      "parameters": {}
    },
    {
      "node_id": "undistort",
      "node_type_id": "custom.opencv.undistort",
      "parameters": {
        "use_optimal_new_camera_matrix": true,
        "alpha": 0.0,
        "crop_to_valid_roi": false
      }
    },
    {
      "node_id": "remap",
      "node_type_id": "custom.opencv.remap",
      "parameters": {
        "interpolation": "linear",
        "border_mode": "constant",
        "border_value": 0
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "alignment-roi",
        "display_name": "Alignment ROI",
        "bbox_xyxy": [
          220,
          140,
          1060,
          660
        ]
      }
    },
    {
      "node_id": "template_match",
      "node_type_id": "custom.opencv.template-match",
      "parameters": {
        "method": "ccoeff-normed",
        "score_threshold": 0.86,
        "max_matches": 1,
        "nms_iou_threshold": 0.3,
        "convert_to_grayscale": true,
        "region_id_prefix": "mark",
        "class_id_default": -1,
        "class_name_default": "reference-mark"
      }
    },
    {
      "node_id": "select_best_region",
      "node_type_id": "core.vision.regions-select-best",
      "parameters": {
        "strategy": "highest-score"
      }
    },
    {
      "node_id": "caliper_edge",
      "node_type_id": "custom.opencv.caliper-edge",
      "parameters": {
        "edge_orientation": "vertical",
        "edge_polarity": "any",
        "profile_reduction": "mean",
        "smoothing_kernel_size": 5,
        "gradient_threshold": 12.0
      }
    },
    {
      "node_id": "extract_edge_strength",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "best_edge_strength"
      }
    },
    {
      "node_id": "inside_check",
      "node_type_id": "core.vision.regions-inside-check",
      "parameters": {
        "match_mode": "all",
        "min_inside_ratio": 0.94
      }
    },
    {
      "node_id": "offset_check",
      "node_type_id": "core.vision.regions-offset-check",
      "parameters": {
        "strategy": "highest-score",
        "max_distance_pixels": 32.0
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "edge_strength_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "ge",
        "threshold": 18.0
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path",
          "template_image_path",
          "undistort_config_path",
          "remap_mapping_path"
        ],
        "fields": {
          "inspection_kind": "calibrated-template-edge-gate",
          "station_id": "alignment-01"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "undistort_config_file",
          "remap_mapping_file",
          "undistort_summary",
          "remap_summary",
          "template_match_summary",
          "selected_region_summary",
          "inside_metrics",
          "offset_metrics",
          "presence_metrics",
          "caliper_summary",
          "edge_strength_metrics"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "inside",
          "offset",
          "edge_strength"
        ],
        "ok_reason": "calibrated template edge gate passed",
        "ng_reason": "calibrated template edge gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "error",
        "alarm_code": "ALIGN-TEMPLATE-EDGE-NG",
        "alarm_message": "calibrated template edge gate failed",
        "clear_message": "calibrated template edge gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/calibrated-template-edge/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/calibrated-template-edge/history.csv"
      }
    }
  ],
  "edges": [
