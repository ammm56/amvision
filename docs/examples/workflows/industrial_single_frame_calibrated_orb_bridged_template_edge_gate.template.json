{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-calibrated-orb-bridged-template-edge-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Calibrated ORB Bridged Template Edge Gate",
  "description": "面向工业单帧现场的 ORB 参考对位后定位样例。输入本地图像路径、参考图路径、模板图路径、本地畸变 JSON 路径和本地 remap JSON 路径；先执行 undistort/remap，再用 ORB + homography 把当前图桥接到参考帧，之后继续接 template-match、caliper-edge 和 ROI 规则链，最后收成 OK/NG、报警对象和本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_reference_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_template_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_undistort_config_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_remap_mapping_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_reference_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_template_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_undistort_config",
      "node_type_id": "core.io.json-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_remap_mapping",
      "node_type_id": "core.io.json-load-local",
      "parameters": {}
    },
    {
      "node_id": "undistort_current",
      "node_type_id": "custom.opencv.undistort",
      "parameters": {
        "use_optimal_new_camera_matrix": true,
        "alpha": 0.0,
        "crop_to_valid_roi": false
      }
    },
    {
      "node_id": "undistort_reference",
      "node_type_id": "custom.opencv.undistort",
      "parameters": {
        "use_optimal_new_camera_matrix": true,
        "alpha": 0.0,
        "crop_to_valid_roi": false
      }
    },
    {
      "node_id": "remap_current",
      "node_type_id": "custom.opencv.remap",
      "parameters": {
        "interpolation": "linear",
        "border_mode": "constant",
        "border_value": 0
      }
    },
    {
      "node_id": "remap_reference",
      "node_type_id": "custom.opencv.remap",
      "parameters": {
        "interpolation": "linear",
        "border_mode": "constant",
        "border_value": 0
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "alignment-roi",
        "display_name": "Alignment ROI",
        "bbox_xyxy": [
          220,
          140,
          1060,
          660
        ]
      }
    },
    {
      "node_id": "orb_current",
      "node_type_id": "custom.opencv.orb-keypoints",
      "parameters": {
        "max_features": 700,
        "scale_factor": 1.2,
        "level_count": 8,
        "edge_threshold": 31,
        "patch_size": 31,
        "fast_threshold": 20,
        "use_roi_mask": true,
        "feature_id_prefix": "cur"
      }
    },
    {
      "node_id": "orb_reference",
      "node_type_id": "custom.opencv.orb-keypoints",
      "parameters": {
        "max_features": 700,
        "scale_factor": 1.2,
        "level_count": 8,
        "edge_threshold": 31,
        "patch_size": 31,
        "fast_threshold": 20,
        "use_roi_mask": true,
        "feature_id_prefix": "ref"
      }
    },
    {
      "node_id": "orb_match",
      "node_type_id": "custom.opencv.orb-match",
      "parameters": {
        "cross_check": false,
        "ratio_test_threshold": 0.82,
        "max_matches": 120
      }
    },
    {
      "node_id": "homography_estimate",
      "node_type_id": "custom.opencv.homography-estimate",
      "parameters": {
        "method": "ransac",
        "ransac_reprojection_threshold": 4.0,
        "confidence": 0.995,
        "max_iters": 2000,
        "min_match_count": 12,
        "include_inverse_matrix": true
      }
    },
    {
      "node_id": "bridge_current_to_reference",
      "node_type_id": "custom.opencv.planar-transform-bridge",
      "parameters": {
        "direction": "source-a-to-source-b",
        "border_mode": "constant",
        "border_value": 0,
        "output_roi_id": "reference-frame-alignment-roi",
        "output_display_name": "Reference Frame Alignment ROI"
      }
    },
    {
      "node_id": "extract_inlier_count",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "inlier_count"
      }
    },
    {
      "node_id": "extract_inlier_ratio",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "inlier_ratio"
      }
    },
    {
      "node_id": "extract_reprojection_error",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "reprojection_error"
      }
    },
    {
      "node_id": "inlier_count_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "ge",
        "threshold": 24.0
      }
    },
    {
      "node_id": "inlier_ratio_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "ge",
        "threshold": 0.45
      }
    },
    {
      "node_id": "reprojection_error_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "max_value": 4.0,
        "max_inclusive": true
      }
    },
    {
      "node_id": "template_match",
      "node_type_id": "custom.opencv.template-match",
      "parameters": {
        "method": "ccoeff-normed",
        "score_threshold": 0.86,
        "max_matches": 1,
        "nms_iou_threshold": 0.3,
        "convert_to_grayscale": true,
        "region_id_prefix": "mark",
        "class_id_default": -1,
        "class_name_default": "reference-mark"
      }
    },
    {
      "node_id": "select_best_region",
      "node_type_id": "core.vision.regions-select-best",
      "parameters": {
        "strategy": "highest-score"
      }
    },
    {
      "node_id": "caliper_edge",
      "node_type_id": "custom.opencv.caliper-edge",
      "parameters": {
        "edge_orientation": "vertical",
        "edge_polarity": "any",
        "profile_reduction": "mean",
        "smoothing_kernel_size": 5,
        "gradient_threshold": 12.0
      }
    },
    {
      "node_id": "extract_edge_strength",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "best_edge_strength"
      }
    },
    {
      "node_id": "inside_check",
      "node_type_id": "core.vision.regions-inside-check",
      "parameters": {
        "match_mode": "all",
        "min_inside_ratio": 0.94
      }
    },
    {
      "node_id": "offset_check",
      "node_type_id": "core.vision.regions-offset-check",
      "parameters": {
        "strategy": "highest-score",
        "max_distance_pixels": 32.0
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "edge_strength_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "ge",
        "threshold": 18.0
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path",
          "reference_image_path",
          "template_image_path",
          "undistort_config_path",
          "remap_mapping_path"
        ],
        "fields": {
          "inspection_kind": "calibrated-orb-bridged-template-edge-gate",
          "station_id": "alignment-03"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "current_undistort_summary",
          "current_remap_summary",
          "reference_undistort_summary",
          "reference_remap_summary",
          "current_orb_summary",
          "reference_orb_summary",
          "match_summary",
          "homography_summary",
          "bridge_summary",
          "inlier_count_metrics",
          "inlier_ratio_metrics",
          "reprojection_error_metrics",
          "template_match_summary",
          "selected_region_summary",
          "inside_metrics",
          "offset_metrics",
          "presence_metrics",
          "caliper_summary",
          "edge_strength_metrics"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "inlier_count",
          "inlier_ratio",
          "reprojection_error",
          "presence",
          "inside",
          "offset",
          "edge_strength"
        ],
        "ok_reason": "calibrated orb bridged template edge gate passed",
        "ng_reason": "calibrated orb bridged template edge gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "error",
        "alarm_code": "ALIGN-ORB-BRIDGED-TEMPLATE-EDGE-NG",
        "alarm_message": "calibrated orb bridged template edge gate failed",
        "clear_message": "calibrated orb bridged template edge gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/calibrated-orb-bridged-template-edge/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
