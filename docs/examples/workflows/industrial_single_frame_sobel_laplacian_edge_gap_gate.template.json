{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-sobel-laplacian-edge-gap-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Sobel Laplacian Edge Gap Gate",
  "description": "面向工业单帧边线完整性现场的传统视觉样例。输入本地图像路径和可选 ROI；先收紧工位窗口，再并联执行 sobel 与 laplacian 边缘增强。sobel 支路负责 contour/regions 和缺口规则，laplacian 支路负责边缘强度辅助条件，最后统一收成 OK/NG、报警对象和本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "edge-gap-roi",
        "display_name": "Edge Gap ROI",
        "bbox_xyxy": [
          120,
          180,
          1180,
          520
        ]
      }
    },
    {
      "node_id": "crop_roi",
      "node_type_id": "custom.opencv.crop",
      "parameters": {
        "padding": 8
      }
    },
    {
      "node_id": "sobel",
      "node_type_id": "custom.opencv.sobel",
      "parameters": {
        "direction": "y",
        "kernel_size": 3,
        "scale": 1.0,
        "delta": 0.0,
        "convert_to_grayscale": true
      }
    },
    {
      "node_id": "laplacian",
      "node_type_id": "custom.opencv.laplacian",
      "parameters": {
        "kernel_size": 3,
        "scale": 1.0,
        "delta": 0.0,
        "convert_to_grayscale": true
      }
    },
    {
      "node_id": "edge_threshold",
      "node_type_id": "custom.opencv.binary-threshold",
      "parameters": {
        "threshold": 48.0,
        "max_value": 255.0
      }
    },
    {
      "node_id": "contour",
      "node_type_id": "custom.opencv.contour",
      "parameters": {
        "retrieval_mode": "external",
        "min_area": 40.0
      }
    },
    {
      "node_id": "filter_contours",
      "node_type_id": "custom.opencv.contour-filter",
      "parameters": {
        "min_area": 120.0,
        "sort_by": "area",
        "descending": true,
        "limit": 6
      }
    },
    {
      "node_id": "draw_review_contours",
      "node_type_id": "custom.opencv.draw-contours",
      "parameters": {
        "draw_indices": true,
        "draw_bbox": false,
        "line_thickness": 2,
        "font_scale": 0.5
      }
    },
    {
      "node_id": "contours_to_regions",
      "node_type_id": "custom.opencv.contours-to-regions",
      "parameters": {
        "region_id_prefix": "edge",
        "class_id_default": -1,
        "class_name_default": "edge-band",
        "score_default": 1.0
      }
    },
    {
      "node_id": "edge_profile_gap_check",
      "node_type_id": "core.vision.edge-profile-gap-check",
      "parameters": {
        "edge_orientation": "horizontal",
        "min_gap_pixels_to_count": 3,
        "max_gap_pixels": 6,
        "max_gap_count": 0,
        "min_axis_occupancy_ratio": 0.82
      }
    },
    {
      "node_id": "edge_break_check",
      "node_type_id": "core.vision.edge-break-check",
      "parameters": {
        "match_mode": "all",
        "min_gap_pixels_to_count": 3,
        "max_gap_pixels": 6,
        "max_gap_count": 0,
        "min_elongation_ratio": 2.0,
        "min_axis_occupancy_ratio": 0.82
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1
      }
    },
    {
      "node_id": "edge_area_ratio",
      "node_type_id": "core.vision.regions-area-ratio",
      "parameters": {}
    },
    {
      "node_id": "edge_area_ratio_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "min_value": 0.02,
        "max_value": 0.45,
        "min_inclusive": true,
        "max_inclusive": true
      }
    },
    {
      "node_id": "extract_laplacian_mean_intensity",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "mean_edge_intensity"
      }
    },
    {
      "node_id": "laplacian_intensity_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "ge",
        "threshold": 8.0
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path"
        ],
        "fields": {
          "inspection_kind": "sobel-laplacian-edge-gap-gate",
          "station_id": "edge-gap-01",
          "target_profile": "horizontal-edge-band"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "roi_summary",
          "crop_summary",
          "sobel_summary",
          "laplacian_summary",
          "filtered_contour_summary",
          "region_summary",
          "profile_gap_metrics",
          "edge_break_metrics",
          "presence_metrics",
          "area_ratio",
          "area_ratio_metrics",
          "laplacian_intensity_metrics"
        ],
        "fields": {
          "preprocess_chain": [
            "crop",
            "sobel",
            "laplacian"
          ]
        }
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "profile_gap",
          "edge_break",
          "area_ratio",
          "laplacian_intensity"
        ],
        "ok_reason": "sobel laplacian edge gap gate passed",
        "ng_reason": "sobel laplacian edge gap gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "warning",
        "alarm_code": "EDGE-GAP-GATE-NG",
        "alarm_message": "sobel laplacian edge gap gate failed",
        "clear_message": "sobel laplacian edge gap gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/sobel-laplacian-edge-gap/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/sobel-laplacian-edge-gap/history.csv"
      }
    }
  ],
  "edges": [
    {
