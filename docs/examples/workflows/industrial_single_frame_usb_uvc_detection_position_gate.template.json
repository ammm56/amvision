{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-usb-uvc-detection-position-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame USB/UVC Detection Position Gate",
  "description": "面向工业单帧现场的 USB / UVC 相机检测到规则闭环样例。输入相机抓图配置、已发布 deployment 请求，以及可选运行时 ROI；先从 USB / UVC 相机直采单帧，再执行检测，桥接成 regions.v1 完成存在性、落位和偏移门判定，并输出带复核图像引用的 result-record 与本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_camera_config_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "deployment_request_input",
      "node_type_id": "core.io.template-input.object",
      "parameters": {}
    },
    {
      "node_id": "capture_frame",
      "node_type_id": "custom.camera.usb.capture-frame",
      "parameters": {
        "device_index": 0,
        "backend_preference": "any",
        "width": 1280,
        "height": 720,
        "fps": 15.0,
        "warmup_frame_count": 2,
        "retry_read_count": 3,
        "output_format": "png"
      }
    },
    {
      "node_id": "detect",
      "node_type_id": "core.model.yolox-detection",
      "parameters": {
        "auto_start_process": true,
        "score_threshold": 0.4,
        "save_result_image": false,
        "return_preview_image_base64": false
      }
    },
    {
      "node_id": "draw_detections",
      "node_type_id": "custom.opencv.draw-detections",
      "parameters": {
        "line_thickness": 2,
        "font_scale": 0.5,
        "draw_scores": true
      }
    },
    {
      "node_id": "detections_to_regions",
      "node_type_id": "core.vision.detections-to-regions",
      "parameters": {
        "region_id_prefix": "det",
        "class_id_default": -1
      }
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "class_names": [
          "part"
        ],
        "min_score": 0.55
      }
    },
    {
      "node_id": "select_best_region",
      "node_type_id": "core.vision.regions-select-best",
      "parameters": {
        "strategy": "largest-area"
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "camera-position-roi",
        "display_name": "Camera Position ROI",
        "bbox_xyxy": [
          220,
          140,
          1040,
          640
        ]
      }
    },
    {
      "node_id": "draw_roi",
      "node_type_id": "custom.opencv.draw-roi",
      "parameters": {
        "fill_alpha": 0.16,
        "draw_bbox": true
      }
    },
    {
      "node_id": "inside_check",
      "node_type_id": "core.vision.regions-inside-check",
      "parameters": {
        "match_mode": "all",
        "min_inside_ratio": 0.95
      }
    },
    {
      "node_id": "offset_check",
      "node_type_id": "core.vision.regions-offset-check",
      "parameters": {
        "strategy": "largest-area",
        "max_distance_pixels": 28.0
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "camera_config",
          "deployment_request"
        ],
        "fields": {
          "inspection_kind": "usb-uvc-detection-position-gate",
          "station_id": "camera-line-01",
          "input_kind": "usb-uvc-camera",
          "model_kind": "yolox-detection"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "capture_summary",
          "convert_summary",
          "filter_summary",
          "inside_metrics",
          "offset_metrics",
          "presence_metrics",
          "roi_summary"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "inside",
          "offset"
        ],
        "ok_reason": "usb uvc yolox position gate passed",
        "ng_reason": "usb uvc yolox position gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "error",
        "alarm_code": "USB-UVC-DETECTION-POS-NG",
        "alarm_message": "usb uvc yolox position gate failed",
        "clear_message": "usb uvc yolox position gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/camera-usb-uvc-detection-position-gate/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/camera-usb-uvc-detection-position-gate/history.csv"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-camera-config-capture",
      "source_node_id": "request_camera_config_input",
      "source_port": "value",
      "target_node_id": "capture_frame",
      "target_port": "request"
    },
    {
      "edge_id": "edge-camera-config-metadata",
      "source_node_id": "request_camera_config_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-deployment-request-detect",
      "source_node_id": "deployment_request_input",
      "source_port": "value",
      "target_node_id": "detect",
      "target_port": "request"
    },
    {
      "edge_id": "edge-deployment-request-metadata",
      "source_node_id": "deployment_request_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-capture-detect-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "detect",
      "target_port": "image"
    },
    {
      "edge_id": "edge-capture-draw-detections-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "draw_detections",
      "target_port": "image"
    },
    {
      "edge_id": "edge-capture-convert-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "detections_to_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-detect-draw-detections",
      "source_node_id": "detect",
      "source_port": "detections",
      "target_node_id": "draw_detections",
      "target_port": "detections"
    },
    {
      "edge_id": "edge-detect-convert-detections",
      "source_node_id": "detect",
      "source_port": "detections",
      "target_node_id": "detections_to_regions",
      "target_port": "detections"
    },
    {
      "edge_id": "edge-draw-detections-draw-roi",
      "source_node_id": "draw_detections",
      "source_port": "image",
      "target_node_id": "draw_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-convert-filter-regions",
      "source_node_id": "detections_to_regions",
      "source_port": "regions",
      "target_node_id": "filter_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-select-best",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "select_best_region",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-presence-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "presence_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-draw-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "draw_roi",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-select-best-inside-regions",
      "source_node_id": "select_best_region",
      "source_port": "regions",
      "target_node_id": "inside_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-inside-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "inside_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-select-best-offset-regions",
      "source_node_id": "select_best_region",
      "source_port": "regions",
      "target_node_id": "offset_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-offset-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "offset_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-capture-summary-metrics",
      "source_node_id": "capture_frame",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-convert-summary-metrics",
      "source_node_id": "detections_to_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-filter-summary-metrics",
      "source_node_id": "filter_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-inside-metrics-object",
      "source_node_id": "inside_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-offset-metrics-object",
      "source_node_id": "offset_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-metrics-object",
      "source_node_id": "presence_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-roi-summary-metrics-object",
      "source_node_id": "create_roi",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-process",
      "source_node_id": "presence_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-inside-process",
      "source_node_id": "inside_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-offset-process",
      "source_node_id": "offset_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-metrics-process",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-process",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-overlay-image-process",
      "source_node_id": "draw_roi",
      "source_port": "image",
      "target_node_id": "process_decision",
      "target_port": "image"
    },
    {
      "edge_id": "edge-process-ok-alarm",
      "source_node_id": "process_decision",
      "source_port": "ok",
      "target_node_id": "alarm_condition",
      "target_port": "condition"
    },
    {
      "edge_id": "edge-metrics-alarm",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-alarm",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-save-json",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "save_result_json",
      "target_port": "result"
    },
    {
      "edge_id": "edge-process-append-csv",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "append_result_csv",
      "target_port": "result"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_camera_config",
      "display_name": "Request Camera Config",
      "payload_type_id": "value.v1",
      "target_node_id": "request_camera_config_input",
      "target_port": "payload"
    },
    {
      "input_id": "deployment_request",
      "display_name": "Deployment Request",
      "payload_type_id": "value.v1",
      "target_node_id": "deployment_request_input",
      "target_port": "payload"
    },
    {
      "input_id": "request_roi",
      "display_name": "Request ROI",
      "payload_type_id": "value.v1",
      "target_node_id": "create_roi",
      "target_port": "value",
      "required": false
    }
  ],
  "template_outputs": [
    {
      "output_id": "captured_image",
      "display_name": "Captured Image",
      "payload_type_id": "image-ref.v1",
      "source_node_id": "capture_frame",
      "source_port": "image"
    },
    {
      "output_id": "capture_summary",
      "display_name": "Capture Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "capture_frame",
      "source_port": "summary"
    },
    {
      "output_id": "model_detections",
      "display_name": "Model Detections",
      "payload_type_id": "detections.v1",
      "source_node_id": "detect",
      "source_port": "detections"
    },
    {
      "output_id": "model_regions",
      "display_name": "Model Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "detections_to_regions",
      "source_port": "regions"
    },
    {
      "output_id": "effective_roi",
      "display_name": "Effective ROI",
      "payload_type_id": "roi.v1",
      "source_node_id": "create_roi",
      "source_port": "roi"
    },
    {
      "output_id": "review_overlay_image",
      "display_name": "Review Overlay Image",
      "payload_type_id": "image-ref.v1",
      "source_node_id": "draw_roi",
      "source_port": "image"
    },
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "inspection_alarm",
      "display_name": "Inspection Alarm",
      "payload_type_id": "alarm-record.v1",
      "source_node_id": "alarm_condition",
      "source_port": "alarm"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    },
    {
      "output_id": "json_summary",
      "display_name": "JSON Save Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_result_json",
      "source_port": "summary"
    },
    {
      "output_id": "csv_summary",
      "display_name": "CSV Append Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "append_result_csv",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-usb-uvc-detection-position-gate",
    "focus": "single-frame-industrial-camera-detection-rule-chain",
    "transport": "usb-uvc",
    "uses_existing_deployment_instance": true,
    "dynamic_roi_input_binding": "request_roi",
    "node_groups": {
      "input": [
        "request_camera_config_input",
        "deployment_request_input"
      ],
      "capture": [
        "capture_frame"
      ],
      "model_and_bridge": [
        "detect",
        "draw_detections",
        "detections_to_regions",
        "filter_regions",
        "select_best_region"
      ],
      "roi_and_rules": [
        "create_roi",
        "draw_roi",
        "inside_check",
        "offset_check",
        "presence_check"
      ],
      "decision_and_alarm": [
        "metadata_object",
        "metrics_object",
        "process_decision",
        "alarm_condition"
      ],
      "output": [
        "save_result_json",
        "append_result_csv"
      ]
    }
  }
}
