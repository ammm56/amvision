{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-local-directory-polling-cursor-guard-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Local Directory Polling Cursor Guard",
  "description": "面向工业现场本地目录轮询的状态守护样例。输入目录路径和可选批次大小；读取本地 cursor 状态、按文件稳定期扫描目录、解析下一段 polling window，并把更新后的 cursor 与批次归档摘要持久化到本地 JSON。",
  "nodes": [
    {
      "node_id": "request_directory_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_cursor_state",
      "node_type_id": "core.io.json-load-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-polling-cursor-guard/cursor.json",
        "allow_missing": true,
        "allow_invalid_json": true,
        "default_value": {
          "next_start_index": 0
        }
      }
    },
    {
      "node_id": "scan_directory",
      "node_type_id": "core.io.directory-scan",
      "parameters": {
        "recursive": false,
        "include_hidden": false,
        "extensions": [
          "png",
          "jpg",
          "jpeg",
          "bmp"
        ],
        "sort_by": "modified_time",
        "descending": false,
        "min_stable_age_seconds": 1.0,
        "dedupe_by": "path"
      }
    },
    {
      "node_id": "poll_window",
      "node_type_id": "core.io.directory-poll-window",
      "parameters": {
        "start_index": 0,
        "batch_size": 8
      }
    },
    {
      "node_id": "batch_archive_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "directory_path",
          "cursor_load_summary",
          "cursor_before",
          "scan_summary",
          "poll_summary",
          "batch_cursor",
          "batch_files"
        ],
        "fields": {
          "example_kind": "industrial-local-directory-polling-cursor-guard",
          "archive_schema_version": "industrial-directory-poll-archive.v1",
          "polling_mode": "stateful-local-json-cursor",
          "cursor_state_relative_path": "industrial-local-directory-polling-cursor-guard/cursor.json",
          "json_archive_pattern": "industrial-local-directory-polling-cursor-guard/archive/batch-{timestamp}.json",
          "file_stability_policy": {
            "min_stable_age_seconds": 1.0,
            "dedupe_by": "path"
          }
        }
      }
    },
    {
      "node_id": "save_cursor_state",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-polling-cursor-guard/cursor.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "save_batch_archive",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-polling-cursor-guard/archive/batch-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-directory-path-scan",
      "source_node_id": "request_directory_path_input",
      "source_port": "value",
      "target_node_id": "scan_directory",
      "target_port": "path"
    },
    {
      "edge_id": "edge-scan-directory-poll-window",
      "source_node_id": "scan_directory",
      "source_port": "files",
      "target_node_id": "poll_window",
      "target_port": "files"
    },
    {
      "edge_id": "edge-load-cursor-poll-window",
      "source_node_id": "load_cursor_state",
      "source_port": "value",
      "target_node_id": "poll_window",
      "target_port": "cursor"
    },
    {
      "edge_id": "edge-request-directory-path-archive",
      "source_node_id": "request_directory_path_input",
      "source_port": "value",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-cursor-load-summary-archive",
      "source_node_id": "load_cursor_state",
      "source_port": "summary",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-cursor-before-archive",
      "source_node_id": "load_cursor_state",
      "source_port": "value",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-scan-summary-archive",
      "source_node_id": "scan_directory",
      "source_port": "summary",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-poll-summary-archive",
      "source_node_id": "poll_window",
      "source_port": "summary",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-batch-cursor-archive",
      "source_node_id": "poll_window",
      "source_port": "cursor",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-batch-files-archive",
      "source_node_id": "poll_window",
      "source_port": "files",
      "target_node_id": "batch_archive_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-poll-cursor-save",
      "source_node_id": "poll_window",
      "source_port": "cursor",
      "target_node_id": "save_cursor_state",
      "target_port": "value"
    },
    {
      "edge_id": "edge-batch-archive-save",
      "source_node_id": "batch_archive_object",
      "source_port": "value",
      "target_node_id": "save_batch_archive",
      "target_port": "value"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_directory_path",
      "display_name": "Request Directory Path",
      "payload_type_id": "value.v1",
      "target_node_id": "request_directory_path_input",
      "target_port": "payload"
    },
    {
      "input_id": "request_batch_size",
      "display_name": "Request Batch Size",
      "payload_type_id": "value.v1",
      "target_node_id": "poll_window",
      "target_port": "batch_size",
      "required": false
    }
  ],
  "template_outputs": [
    {
      "output_id": "has_work",
      "display_name": "Has Work",
      "payload_type_id": "boolean.v1",
      "source_node_id": "poll_window",
      "source_port": "has_work"
    },
    {
      "output_id": "batch_files",
      "display_name": "Batch Files",
      "payload_type_id": "value.v1",
      "source_node_id": "poll_window",
      "source_port": "files"
    },
    {
      "output_id": "scan_summary",
      "display_name": "Scan Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "scan_directory",
      "source_port": "summary"
    },
    {
      "output_id": "poll_summary",
      "display_name": "Poll Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "poll_window",
      "source_port": "summary"
    },
    {
      "output_id": "batch_cursor",
      "display_name": "Batch Cursor",
      "payload_type_id": "value.v1",
      "source_node_id": "poll_window",
      "source_port": "cursor"
    },
    {
      "output_id": "cursor_state",
      "display_name": "Cursor State",
      "payload_type_id": "value.v1",
      "source_node_id": "load_cursor_state",
      "source_port": "value"
    },
    {
      "output_id": "cursor_load_summary",
      "display_name": "Cursor Load Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "load_cursor_state",
      "source_port": "summary"
    },
    {
      "output_id": "cursor_save_summary",
      "display_name": "Cursor Save Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_cursor_state",
      "source_port": "summary"
    },
    {
      "output_id": "batch_archive",
      "display_name": "Batch Archive",
      "payload_type_id": "value.v1",
      "source_node_id": "batch_archive_object",
      "source_port": "value"
    },
    {
      "output_id": "archive_summary",
      "display_name": "Archive Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_batch_archive",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-local-directory-polling-cursor-guard",
    "focus": "local-directory-polling-guard",
    "uses_persisted_local_cursor": true,
    "dynamic_batch_size_binding": "request_batch_size",
    "node_groups": {
      "input": [
        "request_directory_path_input",
        "load_cursor_state"
      ],
      "scan_and_poll": [
        "scan_directory",
        "poll_window"
      ],
      "archive": [
        "batch_archive_object",
        "save_cursor_state",
        "save_batch_archive"
      ]
    }
  }
}
