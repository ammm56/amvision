{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "plc-modbus-wait-ready-ack-callback-template",
  "template_version": "1.0.0",
  "display_name": "PLC Modbus Wait Ready Ack Callback",
  "description": "面向工业现场握手闭环的 Modbus TCP 样例。先等待状态字 ready 掩码命中，再写入确认位，最后把统一 result-record 回传到 HTTP 接口。",
  "nodes": [
    {
      "node_id": "request_wait_config_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_ack_write_config_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "wait_status_word_ready",
      "node_type_id": "custom.plc.modbus.wait-condition",
      "parameters": {
        "host": "127.0.0.1",
        "port": 502,
        "unit_id": 1,
        "timeout_seconds": 1.0,
        "register_address": "400101",
        "data_type": "uint16",
        "operator": "bitmask_all_set",
        "expected_value": 5,
        "poll_interval_ms": 100,
        "wait_timeout_seconds": 60.0,
        "stable_match_count": 2
      }
    },
    {
      "node_id": "build_ack_write_request",
      "node_type_id": "core.logic.object-update",
      "parameters": {
        "paths": [
          "wait_context"
        ]
      }
    },
    {
      "node_id": "write_ack_signal",
      "node_type_id": "custom.plc.modbus.write-value",
      "parameters": {
        "host": "127.0.0.1",
        "port": 502,
        "unit_id": 1,
        "timeout_seconds": 1.0,
        "register_address": "00021",
        "data_type": "bool",
        "value": true
      }
    },
    {
      "node_id": "extract_wait_matched",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "matched"
      }
    },
    {
      "node_id": "compare_wait_matched",
      "node_type_id": "core.logic.compare",
      "parameters": {
        "operator": "eq",
        "right_value": true
      }
    },
    {
      "node_id": "decide_result",
      "node_type_id": "core.rule.ok-ng-decision",
      "parameters": {
        "mode": "all"
      }
    },
    {
      "node_id": "build_result_metrics",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "wait_result",
          "ack_write_result"
        ],
        "fields": {
          "example_kind": "plc-modbus-wait-ready-ack-callback",
          "handshake_stage": "ready-to-ack"
        }
      }
    },
    {
      "node_id": "build_result_metadata",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "wait_config",
          "ack_write_config"
        ],
        "fields": {
          "example_kind": "plc-modbus-wait-ready-ack-callback",
          "description": "wait ready status word, write ack signal, then callback result-record",
          "callback_url": "http://127.0.0.1:18080/plc/modbus/handshake-result",
          "wait_timeout_mode": "finite-seconds"
        }
      }
    },
    {
      "node_id": "inspection_result",
      "node_type_id": "core.output.result-record",
      "parameters": {}
    },
    {
      "node_id": "callback_result",
      "node_type_id": "core.output.http-post",
      "parameters": {
        "url": "http://127.0.0.1:18080/plc/modbus/handshake-result",
        "method": "POST",
        "timeout_seconds": 3.0,
        "require_success": false,
        "headers": {
          "X-Amvision-Example": "plc-modbus-ready-ack-callback"
        }
      }
    }
  ],
