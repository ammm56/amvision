{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-detection-position-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Detection Position Gate",
  "description": "面向工业单帧现场的检测到规则闭环样例。输入本地图像路径、已发布 deployment 请求，以及可选的运行时 ROI；先执行检测，再把 detections.v1 转成 regions.v1，最后完成存在性、落位和偏移门判定，并输出结构化结果与本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "deployment_request_input",
      "node_type_id": "core.io.template-input.object",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "detect",
      "node_type_id": "core.model.detection",
      "parameters": {
        "auto_start_process": true,
        "score_threshold": 0.4,
        "save_result_image": false,
        "return_preview_image_base64": false
      }
    },
    {
      "node_id": "detections_to_regions",
      "node_type_id": "core.vision.detections-to-regions",
      "parameters": {
        "region_id_prefix": "det",
        "class_id_default": -1
      }
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "class_names": [
          "part"
        ],
        "min_score": 0.55
      }
    },
    {
      "node_id": "select_best_region",
      "node_type_id": "core.vision.regions-select-best",
      "parameters": {
        "strategy": "largest-area"
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "position-roi",
        "display_name": "Position ROI",
        "bbox_xyxy": [
          220,
          140,
          1040,
          640
        ]
      }
    },
    {
      "node_id": "inside_check",
      "node_type_id": "core.vision.regions-inside-check",
      "parameters": {
        "match_mode": "all",
        "min_inside_ratio": 0.95
      }
    },
    {
      "node_id": "offset_check",
      "node_type_id": "core.vision.regions-offset-check",
      "parameters": {
        "strategy": "largest-area",
        "max_distance_pixels": 28.0
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path",
          "deployment_request"
        ],
        "fields": {
          "inspection_kind": "detection-position-gate",
          "station_id": "line-c-01"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "convert_summary",
          "filter_summary",
          "inside_metrics",
          "offset_metrics",
          "presence_metrics"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "inside",
          "offset"
        ],
        "ok_reason": "detection position gate passed",
        "ng_reason": "detection position gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "error",
        "alarm_code": "DETECTION-POS-NG",
        "alarm_message": "detection position gate failed",
        "clear_message": "detection position gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/detection-position-gate/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/detection-position-gate/history.csv"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-image-path-load-image",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "load_image",
      "target_port": "path"
    },
    {
      "edge_id": "edge-request-image-path-metadata",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-deployment-request-detect",
      "source_node_id": "deployment_request_input",
      "source_port": "value",
      "target_node_id": "detect",
      "target_port": "request"
    },
    {
      "edge_id": "edge-deployment-request-metadata",
      "source_node_id": "deployment_request_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-load-image-detect",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "detect",
      "target_port": "image"
    },
    {
      "edge_id": "edge-detect-convert-detections",
      "source_node_id": "detect",
      "source_port": "detections",
      "target_node_id": "detections_to_regions",
      "target_port": "detections"
    },
    {
      "edge_id": "edge-load-image-convert-image",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "detections_to_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-convert-filter-regions",
      "source_node_id": "detections_to_regions",
      "source_port": "regions",
      "target_node_id": "filter_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-select-best",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "select_best_region",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-select-best-inside-regions",
      "source_node_id": "select_best_region",
      "source_port": "regions",
      "target_node_id": "inside_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-inside-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "inside_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-select-best-offset-regions",
      "source_node_id": "select_best_region",
      "source_port": "regions",
      "target_node_id": "offset_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-offset-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "offset_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-filter-presence-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "presence_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-convert-summary-metrics",
      "source_node_id": "detections_to_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-filter-summary-metrics",
      "source_node_id": "filter_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-inside-metrics-object",
      "source_node_id": "inside_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-offset-metrics-object",
      "source_node_id": "offset_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-metrics-object",
      "source_node_id": "presence_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-process",
      "source_node_id": "presence_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-inside-process",
      "source_node_id": "inside_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-offset-process",
      "source_node_id": "offset_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-metrics-process",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-process",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-ok-alarm",
      "source_node_id": "process_decision",
      "source_port": "ok",
      "target_node_id": "alarm_condition",
      "target_port": "condition"
    },
    {
      "edge_id": "edge-metrics-alarm",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-alarm",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-save-json",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "save_result_json",
      "target_port": "result"
    },
    {
      "edge_id": "edge-process-append-csv",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "append_result_csv",
      "target_port": "result"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_image_path",
      "display_name": "Request Image Path",
      "payload_type_id": "value.v1",
      "target_node_id": "request_image_path_input",
      "target_port": "payload"
    },
    {
      "input_id": "deployment_request",
      "display_name": "Deployment Request",
      "payload_type_id": "value.v1",
      "target_node_id": "deployment_request_input",
      "target_port": "payload"
    },
    {
      "input_id": "request_roi",
      "display_name": "Request ROI",
      "payload_type_id": "value.v1",
      "target_node_id": "create_roi",
      "target_port": "value",
      "required": false
    }
  ],
  "template_outputs": [
    {
      "output_id": "model_detections",
      "display_name": "Model Detections",
      "payload_type_id": "detections.v1",
      "source_node_id": "detect",
      "source_port": "detections"
    },
    {
      "output_id": "model_regions",
      "display_name": "Model Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "detections_to_regions",
      "source_port": "regions"
    },
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "inspection_alarm",
      "display_name": "Inspection Alarm",
      "payload_type_id": "alarm-record.v1",
      "source_node_id": "alarm_condition",
      "source_port": "alarm"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    },
    {
      "output_id": "json_summary",
      "display_name": "JSON Save Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_result_json",
      "source_port": "summary"
    },
    {
      "output_id": "csv_summary",
      "display_name": "CSV Append Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "append_result_csv",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-detection-position-gate",
    "focus": "single-frame-industrial-detection-rule-chain",
    "uses_existing_deployment_instance": true,
    "dynamic_roi_input_binding": "request_roi",
    "node_groups": {
      "input": [
        "request_image_path_input",
        "deployment_request_input",
        "load_image"
      ],
      "model_and_bridge": [
        "detect",
        "detections_to_regions",
        "filter_regions",
        "select_best_region"
      ],
      "roi_and_rules": [
        "create_roi",
        "inside_check",
        "offset_check",
        "presence_check"
      ],
      "decision_and_alarm": [
        "metadata_object",
        "metrics_object",
        "process_decision",
        "alarm_condition"
      ],
      "output": [
        "save_result_json",
        "append_result_csv"
      ]
    }
  }
}

