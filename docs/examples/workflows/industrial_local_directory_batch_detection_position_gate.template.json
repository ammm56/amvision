{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-local-directory-batch-detection-position-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Local Directory Batch Detection Position Gate",
  "description": "面向工业现场本地目录批处理的检测到规则闭环样例。输入目录路径、可选批次窗口、批次 cursor、已发布 deployment 请求，以及可选运行时 ROI；按批次逐图执行检测，桥接为 regions.v1 后完成存在性、落位和偏移判定，并把单图结果持续追加到 CSV，再在批次结束后输出 JSON 汇总。",
  "nodes": [
    {
      "node_id": "request_directory_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "deployment_request_input",
      "node_type_id": "core.io.template-input.object",
      "parameters": {}
    },
    {
      "node_id": "scan_directory",
      "node_type_id": "core.io.directory-scan",
      "parameters": {
        "recursive": false,
        "include_hidden": false,
        "extensions": [
          "png",
          "jpg",
          "jpeg",
          "bmp"
        ],
        "sort_by": "modified_time",
        "descending": true,
        "limit": 128,
        "min_stable_age_seconds": 1.0
      }
    },
    {
      "node_id": "batch_window",
      "node_type_id": "core.io.directory-batch-window",
      "parameters": {
        "start_index": 0,
        "batch_size": 8
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "position-roi",
        "display_name": "Batch Position ROI",
        "bbox_xyxy": [
          220,
          140,
          1040,
          640
        ]
      }
    },
    {
      "node_id": "iterate_batch",
      "node_type_id": "core.logic.for-each",
      "parameters": {
        "body_node_ids": [
          "get_current_file_record",
          "get_current_file_index",
          "extract_current_file_path",
          "load_image",
          "detect",
          "detections_to_regions",
          "filter_regions",
          "select_best_region",
          "inside_check",
          "offset_check",
          "presence_check",
          "metadata_object",
          "metrics_object",
          "process_decision",
          "append_result_csv"
        ],
        "result_node_id": "process_decision",
        "result_port": "result",
        "item_variable_name": "file_record",
        "index_variable_name": "file_index"
      }
    },
    {
      "node_id": "get_current_file_record",
      "node_type_id": "core.logic.variable.get",
      "parameters": {
        "name": "file_record"
      }
    },
    {
      "node_id": "get_current_file_index",
      "node_type_id": "core.logic.variable.get",
      "parameters": {
        "name": "file_index"
      }
    },
    {
      "node_id": "extract_current_file_path",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "path"
      }
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "detect",
      "node_type_id": "core.model.detection",
      "parameters": {
        "auto_start_process": true,
        "score_threshold": 0.4,
        "save_result_image": false,
        "return_preview_image_base64": false
      }
    },
    {
      "node_id": "detections_to_regions",
      "node_type_id": "core.vision.detections-to-regions",
      "parameters": {
        "region_id_prefix": "det",
        "class_id_default": -1
      }
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "class_names": [
          "part"
        ],
        "min_score": 0.55
      }
    },
    {
      "node_id": "select_best_region",
      "node_type_id": "core.vision.regions-select-best",
      "parameters": {
        "strategy": "largest-area"
      }
    },
    {
      "node_id": "inside_check",
      "node_type_id": "core.vision.regions-inside-check",
      "parameters": {
        "match_mode": "all",
        "min_inside_ratio": 0.95
      }
    },
    {
      "node_id": "offset_check",
      "node_type_id": "core.vision.regions-offset-check",
      "parameters": {
        "strategy": "largest-area",
        "max_distance_pixels": 28.0
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "file_record",
          "file_index",
          "deployment_request"
        ],
        "fields": {
          "inspection_kind": "detection-position-gate-batch",
          "station_id": "line-c-01"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "convert_summary",
          "filter_summary",
          "inside_metrics",
          "offset_metrics",
          "presence_metrics"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "inside",
          "offset"
        ],
        "ok_reason": "batch detection position gate passed",
        "ng_reason": "batch detection position gate failed"
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-batch-detection-position-gate/history.csv"
      }
    },
    {
      "node_id": "batch_summary_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "directory_path",
          "deployment_request",
          "roi_summary",
          "scan_summary",
          "window_summary",
          "window_cursor",
          "batch_files",
          "inspection_results",
          "inspection_result_count"
        ],
        "fields": {
          "example_kind": "industrial-local-directory-batch-detection-position-gate",
          "inspection_kind": "detection-position-gate-batch",
          "archive_root": "workflow_app_result_dir",
          "json_archive_pattern": "industrial-local-directory-batch-detection-position-gate/result-{timestamp}.json",
          "csv_archive_relative_path": "industrial-local-directory-batch-detection-position-gate/history.csv"
        }
      }
    },
    {
      "node_id": "save_batch_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/industrial-local-directory-batch-detection-position-gate/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-directory-path-scan",
      "source_node_id": "request_directory_path_input",
      "source_port": "value",
