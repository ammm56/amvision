  "metadata": {
    "example_kind": "industrial-local-directory-watch-detection-position-gate",
    "focus": "directory-watch-trigger-industrial-detection-rule-chain",
    "trigger_source_kind": "directory-watch",
    "uses_existing_deployment_instance": true,
    "dynamic_roi_input_binding": "request_roi",
    "callback_url_edit_required": true,
    "input_boundary_note": "TriggerSource 当前只负责映射原始 payload/event 对象；workflow 内使用 payload-to-value 显式桥接，并从 payload.files 读取当前批次文件记录。",
    "node_groups": {
      "input": [
        "wrap_trigger_payload",
        "wrap_trigger_event",
        "deployment_request_input"
      ],
      "trigger_batch": [
        "extract_batch_files",
        "extract_batch_id",
