{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-segments-overlay-review-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Segments Overlay Review",
  "description": "面向工业单帧现场的 segments 复核样例。输入本地图像路径、上游 segments.v1，以及可选的运行时 ROI；先通过 segments-to-regions 统一收成标准 regions.v1，再把 ROI 和区域覆盖层叠加回原图，最后输出复核图、标准化 regions 和带图像引用的 result-record。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "segments_to_regions",
      "node_type_id": "core.vision.segments-to-regions",
      "parameters": {
        "region_id_prefix": "seg",
        "class_id_default": -1
      }
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "min_score": 0.55
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "segments-review-roi",
        "display_name": "Segments Review ROI",
        "bbox_xyxy": [
          220,
          180,
          1080,
          700
        ]
      }
    },
    {
      "node_id": "draw_roi",
      "node_type_id": "custom.opencv.draw-roi",
      "parameters": {
        "fill_alpha": 0.16,
        "draw_bbox": true
      }
    },
    {
      "node_id": "overlay_regions",
      "node_type_id": "custom.opencv.mask-overlay",
      "parameters": {
        "mask_alpha": 0.4,
        "draw_masks": true,
        "draw_polygons": true,
        "draw_boxes": true,
        "draw_labels": true
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1
      }
    },
    {
      "node_id": "coverage_check",
      "node_type_id": "core.vision.regions-coverage-check",
      "parameters": {
        "min_ratio": 0.05
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path"
        ],
        "fields": {
          "inspection_kind": "segments-overlay-review",
          "station_id": "review-line-seg-01",
          "review_mode": "segments-to-regions-overlay"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "convert_summary",
          "filter_summary",
          "presence_metrics",
          "coverage_metrics",
          "roi_summary"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "coverage"
        ],
        "ok_reason": "segments overlay review passed",
        "ng_reason": "segments overlay review failed"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-image-path-load-image",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "load_image",
      "target_port": "path"
    },
    {
      "edge_id": "edge-request-image-path-metadata",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-load-image-convert-image",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "segments_to_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-convert-filter-regions",
      "source_node_id": "segments_to_regions",
      "source_port": "regions",
      "target_node_id": "filter_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-load-image-create-roi",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "create_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-load-image-draw-roi-image",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "draw_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-create-roi-draw-roi-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "draw_roi",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-draw-roi-overlay-image",
      "source_node_id": "draw_roi",
      "source_port": "image",
      "target_node_id": "overlay_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-filter-overlay-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "overlay_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-presence-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "presence_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-coverage-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "coverage_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-coverage-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "coverage_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-convert-summary-metrics",
      "source_node_id": "segments_to_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-filter-summary-metrics",
      "source_node_id": "filter_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-metrics-object",
      "source_node_id": "presence_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-coverage-metrics-object",
      "source_node_id": "coverage_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-roi-summary-metrics-object",
      "source_node_id": "create_roi",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-process",
      "source_node_id": "presence_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-coverage-process",
      "source_node_id": "coverage_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-metrics-process",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-process",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-overlay-image-process",
      "source_node_id": "overlay_regions",
      "source_port": "image",
      "target_node_id": "process_decision",
      "target_port": "image"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_image_path",
      "display_name": "Request Image Path",
      "payload_type_id": "value.v1",
      "target_node_id": "request_image_path_input",
      "target_port": "payload"
    },
    {
      "input_id": "request_segments",
      "display_name": "Request Segments",
      "payload_type_id": "segments.v1",
      "target_node_id": "segments_to_regions",
      "target_port": "segments"
    },
    {
      "input_id": "request_roi",
      "display_name": "Request ROI",
      "payload_type_id": "value.v1",
      "target_node_id": "create_roi",
      "target_port": "value",
      "required": false
    }
  ],
  "template_outputs": [
    {
      "output_id": "normalized_regions",
      "display_name": "Normalized Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "segments_to_regions",
      "source_port": "regions"
    },
    {
      "output_id": "effective_roi",
      "display_name": "Effective ROI",
      "payload_type_id": "roi.v1",
      "source_node_id": "create_roi",
      "source_port": "roi"
    },
    {
      "output_id": "review_overlay_image",
      "display_name": "Review Overlay Image",
      "payload_type_id": "image-ref.v1",
      "source_node_id": "overlay_regions",
      "source_port": "image"
    },
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-segments-overlay-review",
    "focus": "single-frame-industrial-segments-overlay-review",
    "dynamic_roi_input_binding": "request_roi",
    "default_roi_kind": "bbox",
    "node_groups": {
      "input": [
        "request_image_path_input",
        "load_image",
        "segments_to_regions",
        "filter_regions",
        "create_roi"
      ],
      "overlay": [
        "draw_roi",
        "overlay_regions"
      ],
      "review": [
        "presence_check",
        "coverage_check",
        "metadata_object",
        "metrics_object",
        "process_decision"
      ]
    }
  }
}
