{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-line-pair-measure-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Line Pair Measure Gate",
  "description": "面向工业单帧量测现场的双边线样例。输入本地图像路径，提取两条边线，量测槽宽、平行度和中点间距，最后输出 OK/NG、报警对象和本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "otsu",
      "node_type_id": "custom.opencv.otsu-threshold",
      "parameters": {
        "threshold_type": "binary"
      }
    },
    {
      "node_id": "contour",
      "node_type_id": "custom.opencv.contour",
      "parameters": {
        "retrieval_mode": "external",
        "min_area": 20.0
      }
    },
    {
      "node_id": "fit_lines",
      "node_type_id": "custom.opencv.fit-line",
      "parameters": {
        "sort_by": "length_pixels",
        "descending": true
      }
    },
    {
      "node_id": "lines_to_value",
      "node_type_id": "custom.opencv.payload-to-value",
      "parameters": {}
    },
    {
      "node_id": "extract_line_1_midpoint",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "items.0.midpoint_xy"
      }
    },
    {
      "node_id": "extract_line_2_midpoint",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "items.1.midpoint_xy"
      }
    },
    {
      "node_id": "measure_midpoint_distance",
      "node_type_id": "custom.opencv.point-distance",
      "parameters": {
        "output_metric": "distance_pixels"
      }
    },
    {
      "node_id": "measure_parallelism",
      "node_type_id": "custom.opencv.parallelism-metrics",
      "parameters": {
        "line_a_strategy": "longest",
        "line_b_strategy": "shortest",
        "output_metric": "abs_delta_angle_deg"
      }
    },
    {
      "node_id": "measure_slot_width",
      "node_type_id": "custom.opencv.slot-width",
      "parameters": {
        "line_a_strategy": "longest",
        "line_b_strategy": "shortest",
        "output_metric": "mean_width_pixels"
      }
    },
    {
      "node_id": "slot_width_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "min_value": 30.0,
        "max_value": 60.0,
        "min_inclusive": true,
        "max_inclusive": true
      }
    },
    {
      "node_id": "parallelism_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "max_value": 1.5,
        "max_inclusive": true
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path"
        ],
        "fields": {
          "inspection_kind": "line-pair-measure-gate",
          "station_id": "line-geometry-01"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "midpoint_distance",
          "parallelism_summary",
          "slot_width_summary"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "slot_width",
          "parallelism"
        ],
        "ok_reason": "line pair measure gate passed",
        "ng_reason": "line pair measure gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "warning",
        "alarm_code": "LINE-PAIR-MEASURE-NG",
        "alarm_message": "line pair measure gate failed",
        "clear_message": "line pair measure gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/line-pair-measure/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/line-pair-measure/history.csv"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-image-path-load-image",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "load_image",
      "target_port": "path"
    },
    {
      "edge_id": "edge-request-image-path-metadata",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-load-image-otsu",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "otsu",
      "target_port": "image"
    },
    {
      "edge_id": "edge-otsu-contour",
      "source_node_id": "otsu",
      "source_port": "image",
      "target_node_id": "contour",
      "target_port": "image"
    },
    {
      "edge_id": "edge-contour-fit-lines",
      "source_node_id": "contour",
      "source_port": "contours",
      "target_node_id": "fit_lines",
      "target_port": "contours"
    },
    {
      "edge_id": "edge-fit-lines-to-value",
      "source_node_id": "fit_lines",
      "source_port": "lines",
      "target_node_id": "lines_to_value",
      "target_port": "lines"
    },
    {
      "edge_id": "edge-lines-to-value-midpoint-1",
      "source_node_id": "lines_to_value",
      "source_port": "value",
      "target_node_id": "extract_line_1_midpoint",
      "target_port": "value"
    },
    {
      "edge_id": "edge-lines-to-value-midpoint-2",
      "source_node_id": "lines_to_value",
      "source_port": "value",
      "target_node_id": "extract_line_2_midpoint",
      "target_port": "value"
    },
    {
      "edge_id": "edge-line-1-midpoint-distance",
      "source_node_id": "extract_line_1_midpoint",
      "source_port": "value",
      "target_node_id": "measure_midpoint_distance",
      "target_port": "point_a"
    },
    {
      "edge_id": "edge-line-2-midpoint-distance",
      "source_node_id": "extract_line_2_midpoint",
      "source_port": "value",
      "target_node_id": "measure_midpoint_distance",
      "target_port": "point_b"
    },
    {
      "edge_id": "edge-fit-lines-parallelism",
      "source_node_id": "fit_lines",
      "source_port": "lines",
      "target_node_id": "measure_parallelism",
      "target_port": "lines"
    },
    {
      "edge_id": "edge-fit-lines-slot-width",
      "source_node_id": "fit_lines",
      "source_port": "lines",
      "target_node_id": "measure_slot_width",
      "target_port": "lines"
    },
    {
      "edge_id": "edge-slot-width-check",
      "source_node_id": "measure_slot_width",
      "source_port": "value",
      "target_node_id": "slot_width_check",
      "target_port": "value"
    },
    {
      "edge_id": "edge-parallelism-check",
      "source_node_id": "measure_parallelism",
      "source_port": "value",
      "target_node_id": "parallelism_check",
      "target_port": "value"
    },
    {
      "edge_id": "edge-midpoint-distance-metrics",
      "source_node_id": "measure_midpoint_distance",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-parallelism-summary-metrics",
      "source_node_id": "measure_parallelism",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-slot-width-summary-metrics",
      "source_node_id": "measure_slot_width",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-slot-width-process",
      "source_node_id": "slot_width_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-parallelism-process",
      "source_node_id": "parallelism_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-metrics-process",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-process",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-ok-alarm",
      "source_node_id": "process_decision",
      "source_port": "ok",
      "target_node_id": "alarm_condition",
      "target_port": "condition"
    },
    {
      "edge_id": "edge-metrics-alarm",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-alarm",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-save-json",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "save_result_json",
      "target_port": "result"
    },
    {
      "edge_id": "edge-process-append-csv",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "append_result_csv",
      "target_port": "result"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_image_path",
      "display_name": "Request Image Path",
      "payload_type_id": "value.v1",
      "target_node_id": "request_image_path_input",
      "target_port": "payload"
    }
  ],
  "template_outputs": [
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "inspection_alarm",
      "display_name": "Inspection Alarm",
      "payload_type_id": "alarm-record.v1",
      "source_node_id": "alarm_condition",
      "source_port": "alarm"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    },
    {
      "output_id": "json_summary",
      "display_name": "JSON Save Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_result_json",
      "source_port": "summary"
    },
    {
      "output_id": "csv_summary",
      "display_name": "CSV Append Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "append_result_csv",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-line-pair-measure-gate",
    "focus": "single-frame-industrial-geometry-line-chain",
    "node_groups": {
      "input": [
        "request_image_path_input",
        "load_image"
      ],
      "geometry_measurement": [
        "otsu",
        "contour",
        "fit_lines",
        "lines_to_value",
        "extract_line_1_midpoint",
        "extract_line_2_midpoint",
        "measure_midpoint_distance",
        "measure_parallelism",
        "measure_slot_width"
      ],
      "inspection_rules": [
        "slot_width_check",
        "parallelism_check"
      ],
      "decision_and_alarm": [
        "metadata_object",
        "metrics_object",
        "process_decision",
        "alarm_condition"
      ],
      "output": [
        "save_result_json",
        "append_result_csv"
      ]
    }
  }
}
