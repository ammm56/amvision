{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-yoloe-text-overlay-review-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame YOLOE Text Overlay Review",
  "description": "面向工业单帧现场的 YOLOE 文本提示复核样例。输入本地图像路径、text-prompts.v1，以及可选运行时 ROI；直接执行 YOLOE 文本提示检测，输出 detections / regions，并把 ROI 与检测区域叠加回原图，最后输出带复核图像引用的 result-record。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "detect",
      "node_type_id": "custom.yoloe.text-prompt-detect",
      "parameters": {
        "model_family": "11",
        "model_scale": "s",
        "confidence_threshold": 0.25,
        "iou_threshold": 0.5,
        "max_detections": 32
      }
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "min_score": 0.35
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "polygon",
        "roi_id": "yoloe-review-roi",
        "display_name": "YOLOE Review ROI",
        "polygon_xy": [
          [
            180,
            180
          ],
          [
            360,
            150
          ],
          [
            1000,
            170
          ],
          [
            1100,
            620
          ],
          [
            260,
            660
          ]
        ]
      }
    },
    {
      "node_id": "draw_roi",
      "node_type_id": "custom.opencv.draw-roi",
      "parameters": {
        "fill_alpha": 0.16,
        "draw_bbox": false
      }
    },
    {
      "node_id": "overlay_regions",
      "node_type_id": "custom.opencv.mask-overlay",
      "parameters": {
        "mask_alpha": 0.35,
        "draw_masks": true,
        "draw_polygons": true,
        "draw_boxes": true,
        "draw_labels": true
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1
      }
    },
    {
      "node_id": "inside_check",
      "node_type_id": "core.vision.regions-inside-check",
      "parameters": {
        "match_mode": "any",
        "min_inside_ratio": 0.85
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path"
        ],
        "fields": {
          "inspection_kind": "yoloe-text-overlay-review",
          "station_id": "ov-line-01",
          "model_kind": "yoloe-text"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "model_summary",
          "filter_summary",
          "presence_metrics",
          "inside_metrics",
          "roi_summary"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "inside"
        ],
        "ok_reason": "yoloe text overlay review passed",
        "ng_reason": "yoloe text overlay review failed"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-image-path-load-image",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "load_image",
      "target_port": "path"
    },
    {
      "edge_id": "edge-request-image-path-metadata",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-load-image-detect-image",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "detect",
      "target_port": "image"
    },
    {
      "edge_id": "edge-detect-filter-regions",
      "source_node_id": "detect",
      "source_port": "regions",
      "target_node_id": "filter_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-load-image-create-roi",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "create_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-load-image-draw-roi-image",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "draw_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-create-roi-draw-roi-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "draw_roi",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-draw-roi-overlay-image",
      "source_node_id": "draw_roi",
      "source_port": "image",
      "target_node_id": "overlay_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-filter-overlay-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "overlay_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-presence-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "presence_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-inside-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "inside_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-inside-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "inside_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-model-summary-metrics",
      "source_node_id": "detect",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-filter-summary-metrics",
      "source_node_id": "filter_regions",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-metrics-object",
      "source_node_id": "presence_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-inside-metrics-object",
      "source_node_id": "inside_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-roi-summary-metrics-object",
      "source_node_id": "create_roi",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-process",
      "source_node_id": "presence_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-inside-process",
      "source_node_id": "inside_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-metrics-process",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-process",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-overlay-image-process",
      "source_node_id": "overlay_regions",
      "source_port": "image",
      "target_node_id": "process_decision",
      "target_port": "image"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_image_path",
      "display_name": "Request Image Path",
      "payload_type_id": "value.v1",
      "target_node_id": "request_image_path_input",
      "target_port": "payload"
    },
    {
      "input_id": "request_prompts",
      "display_name": "Request Prompts",
      "payload_type_id": "text-prompts.v1",
      "target_node_id": "detect",
      "target_port": "prompts"
    },
    {
      "input_id": "request_roi",
      "display_name": "Request ROI",
      "payload_type_id": "value.v1",
      "target_node_id": "create_roi",
      "target_port": "value",
      "required": false
    }
  ],
  "template_outputs": [
    {
      "output_id": "model_detections",
      "display_name": "Model Detections",
      "payload_type_id": "detections.v1",
      "source_node_id": "detect",
      "source_port": "detections"
    },
    {
      "output_id": "model_regions",
      "display_name": "Model Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "detect",
      "source_port": "regions"
    },
    {
      "output_id": "filtered_regions",
      "display_name": "Filtered Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "filter_regions",
      "source_port": "regions"
    },
    {
      "output_id": "effective_roi",
      "display_name": "Effective ROI",
      "payload_type_id": "roi.v1",
      "source_node_id": "create_roi",
      "source_port": "roi"
    },
    {
      "output_id": "review_overlay_image",
      "display_name": "Review Overlay Image",
      "payload_type_id": "image-ref.v1",
      "source_node_id": "overlay_regions",
      "source_port": "image"
    },
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-yoloe-text-overlay-review",
    "focus": "single-frame-industrial-yoloe-overlay-review",
    "dynamic_roi_input_binding": "request_roi",
    "default_roi_kind": "polygon",
    "node_groups": {
      "input": [
        "request_image_path_input",
        "load_image",
        "detect",
        "create_roi"
      ],
      "overlay": [
        "filter_regions",
        "draw_roi",
        "overlay_regions"
      ],
      "review": [
        "presence_check",
        "inside_check",
        "metadata_object",
        "metrics_object",
        "process_decision"
      ]
    }
  }
}
