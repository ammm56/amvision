{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-reference-diff-watershed-surface-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Reference Diff Watershed Surface Gate",
  "description": "面向工业单帧现场的参考图差异表面异常样例。输入本地图像路径、参考图路径和可选 ROI；先裁出工位区域，再执行 image-diff、heatmap-preview、absdiff-threshold、watershed 与 connected-components，最后用 foreground-change-ratio、surface-uniformity-metrics 和 presence-check 收成 OK/NG、报警对象、本地归档摘要与复核叠加图。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "request_reference_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "load_reference_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "reference-diff-surface-roi",
        "display_name": "Reference Diff Surface ROI",
        "bbox_xyxy": [
          120,
          120,
          1120,
          760
        ]
      }
    },
    {
      "node_id": "crop_image",
      "node_type_id": "custom.opencv.crop",
      "parameters": {
        "padding": 0
      }
    },
    {
      "node_id": "crop_reference_image",
      "node_type_id": "custom.opencv.crop",
      "parameters": {
        "padding": 0
      }
    },
    {
      "node_id": "image_diff",
      "node_type_id": "custom.opencv.image-diff",
      "parameters": {
        "diff_mode": "grayscale"
      }
    },
    {
      "node_id": "diff_heatmap_preview",
      "node_type_id": "custom.opencv.heatmap-preview",
      "parameters": {
        "colormap": "turbo",
        "normalize_mode": "minmax",
        "blend_alpha": 0.5
      }
    },
    {
      "node_id": "diff_threshold",
      "node_type_id": "custom.opencv.absdiff-threshold",
      "parameters": {
        "threshold": 22,
        "threshold_type": "binary"
      }
    },
    {
      "node_id": "watershed_split",
      "node_type_id": "custom.opencv.watershed",
      "parameters": {
        "foreground_threshold": 0,
        "opening_kernel_size": 3,
        "opening_iterations": 1,
        "background_dilate_iterations": 1,
        "boundary_gap_iterations": 1,
        "distance_threshold_ratio": 0.55
      }
    },
    {
      "node_id": "connected_components",
      "node_type_id": "custom.opencv.connected-components",
      "parameters": {
        "foreground_threshold": 0,
        "connectivity": 8,
        "min_area": 18.0,
        "max_components": 12,
        "region_id_prefix": "surface",
        "class_id_default": 221,
        "class_name_default": "surface-defect-cluster",
        "score_default": 1.0
      }
    },
    {
      "node_id": "overlay_regions",
      "node_type_id": "custom.opencv.mask-overlay",
      "parameters": {
        "mask_alpha": 0.35,
        "draw_masks": true,
        "draw_polygons": true,
        "draw_boxes": true,
        "draw_labels": true
      }
    },
    {
      "node_id": "surface_uniformity_metrics",
      "node_type_id": "core.vision.surface-uniformity-metrics",
      "parameters": {}
    },
    {
      "node_id": "foreground_change_ratio",
      "node_type_id": "core.vision.foreground-change-ratio",
      "parameters": {}
    },
    {
      "node_id": "extract_cluster_density",
      "node_type_id": "core.logic.value-field-extract",
      "parameters": {
        "path": "cluster_count_per_10k_pixels"
      }
    },
    {
      "node_id": "cluster_density_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "le",
        "threshold": 18.0
      }
    },
    {
      "node_id": "foreground_change_ratio_check",
      "node_type_id": "core.rule.threshold-check",
      "parameters": {
        "operator": "le",
        "threshold": 0.012
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 0,
        "max_count": 6
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path",
          "reference_image_path"
        ],
        "fields": {
          "inspection_kind": "reference-diff-watershed-surface-gate",
          "station_id": "reference-diff-surface-01",
          "review_mode": "reference-image-vs-current-image",
          "defect_split_mode": "watershed"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "roi_summary",
          "crop_image_summary",
          "crop_reference_summary",
          "diff_summary",
          "heatmap_summary",
          "threshold_summary",
          "watershed_summary",
          "component_summary",
          "surface_metrics",
          "foreground_change_ratio",
          "presence_metrics",
          "cluster_density_gate",
          "foreground_change_gate"
        ],
        "fields": {
          "preprocess_chain": [
            "crop",
            "image-diff",
            "heatmap-preview",
            "absdiff-threshold",
            "watershed"
          ]
        }
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "defect_count",
          "cluster_density",
          "foreground_change_ratio"
        ],
        "ok_reason": "reference diff watershed surface gate passed",
        "ng_reason": "reference diff watershed surface gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "warning",
        "alarm_code": "REFERENCE-DIFF-SURFACE-NG",
        "alarm_message": "reference diff watershed surface gate failed",
        "clear_message": "reference diff watershed surface gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/reference-diff-surface/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/reference-diff-surface/history.csv"
      }
    }
  ],
