{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-usb-uvc-sam3-semantic-continuity-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame USB/UVC SAM3 Semantic Continuity Gate",
  "description": "面向工业单帧现场的 USB / UVC 相机分割到规则闭环样例。输入相机抓图配置、text-prompts.v1，以及可选运行时 ROI；先从 USB / UVC 相机直采单帧，再执行 SAM3 semantic segmentation，完成覆盖率、面积占比和连续性判定，并输出带复核图像引用的 result-record 与本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_camera_config_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "capture_frame",
      "node_type_id": "custom.camera.usb.capture-frame",
      "parameters": {
        "device_index": 0,
        "backend_preference": "any",
        "width": 1280,
        "height": 720,
        "fps": 15.0,
        "warmup_frame_count": 2,
        "retry_read_count": 3,
        "output_format": "png"
      }
    },
    {
      "node_id": "segment",
      "node_type_id": "custom.sam3.semantic-segment",
      "parameters": {
        "model_scale": "s"
      }
    },
    {
      "node_id": "filter_regions",
      "node_type_id": "core.vision.regions-filter",
      "parameters": {
        "class_names": [
          "sealant"
        ],
        "min_score": 0.3
      }
    },
    {
      "node_id": "create_roi",
      "node_type_id": "core.vision.roi-create",
      "parameters": {
        "roi_kind": "bbox",
        "roi_id": "camera-sealant-roi",
        "display_name": "Camera Sealant ROI",
        "bbox_xyxy": [
          220,
          180,
          1080,
          700
        ]
      }
    },
    {
      "node_id": "draw_roi",
      "node_type_id": "custom.opencv.draw-roi",
      "parameters": {
        "fill_alpha": 0.16,
        "draw_bbox": true
      }
    },
    {
      "node_id": "overlay_regions",
      "node_type_id": "custom.opencv.draw-regions",
      "parameters": {
        "mask_alpha": 0.4,
        "draw_masks": true,
        "draw_polygons": true,
        "draw_boxes": true,
        "draw_labels": true
      }
    },
    {
      "node_id": "area_ratio",
      "node_type_id": "core.vision.regions-area-ratio",
      "parameters": {}
    },
    {
      "node_id": "continuity_score",
      "node_type_id": "core.vision.region-continuity-score",
      "parameters": {}
    },
    {
      "node_id": "gap_check",
      "node_type_id": "core.vision.region-gap-check",
      "parameters": {
        "match_mode": "all",
        "max_component_count": 1,
        "max_hole_count": 0,
        "min_largest_component_ratio": 0.75
      }
    },
    {
      "node_id": "presence_check",
      "node_type_id": "core.rule.presence-check",
      "parameters": {
        "min_count": 1,
        "max_count": 1
      }
    },
    {
      "node_id": "coverage_check",
      "node_type_id": "core.vision.regions-coverage-check",
      "parameters": {
        "min_ratio": 0.04
      }
    },
    {
      "node_id": "area_ratio_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "min_value": 0.02,
        "max_value": 0.18,
        "min_inclusive": true,
        "max_inclusive": true
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "camera_config"
        ],
        "fields": {
          "inspection_kind": "usb-uvc-sam3-semantic-continuity-gate",
          "station_id": "camera-seg-01",
          "input_kind": "usb-uvc-camera",
          "model_kind": "sam3-semantic"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "capture_summary",
          "model_summary",
          "filter_summary",
          "area_ratio",
          "continuity_breakdown",
          "gap_metrics",
          "coverage_metrics",
          "presence_metrics",
          "roi_summary"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "presence",
          "area_ratio",
          "coverage",
          "continuity"
        ],
        "ok_reason": "usb uvc sam3 semantic continuity gate passed",
        "ng_reason": "usb uvc sam3 semantic continuity gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "warning",
        "alarm_code": "USB-UVC-SAM3-SEG-NG",
        "alarm_message": "usb uvc sam3 semantic continuity gate failed",
        "clear_message": "usb uvc sam3 semantic continuity gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/camera-usb-uvc-sam3-semantic-continuity-gate/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/camera-usb-uvc-sam3-semantic-continuity-gate/history.csv"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-camera-config-capture",
      "source_node_id": "request_camera_config_input",
      "source_port": "value",
      "target_node_id": "capture_frame",
      "target_port": "request"
    },
    {
      "edge_id": "edge-camera-config-metadata",
      "source_node_id": "request_camera_config_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-capture-segment-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "segment",
      "target_port": "image"
    },
    {
      "edge_id": "edge-capture-create-roi-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "create_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-capture-draw-roi-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "draw_roi",
      "target_port": "image"
    },
    {
      "edge_id": "edge-capture-area-ratio-image",
      "source_node_id": "capture_frame",
      "source_port": "image",
      "target_node_id": "area_ratio",
      "target_port": "image"
    },
    {
      "edge_id": "edge-segment-filter-regions",
      "source_node_id": "segment",
      "source_port": "regions",
      "target_node_id": "filter_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-draw-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "draw_roi",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-draw-roi-overlay-image",
      "source_node_id": "draw_roi",
      "source_port": "image",
      "target_node_id": "overlay_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-filter-overlay-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "overlay_regions",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-area-ratio-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "area_ratio",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-continuity-score",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "continuity_score",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-gap-check",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "gap_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-presence-check",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "presence_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-filter-coverage-regions",
      "source_node_id": "filter_regions",
      "source_port": "regions",
      "target_node_id": "coverage_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-create-roi-coverage-roi",
      "source_node_id": "create_roi",
      "source_port": "roi",
      "target_node_id": "coverage_check",
      "target_port": "roi"
    },
    {
      "edge_id": "edge-area-ratio-area-ratio-check",
      "source_node_id": "area_ratio",
      "source_port": "value",
      "target_node_id": "area_ratio_check",
      "target_port": "value"
    },
    {
      "edge_id": "edge-capture-summary-metrics",
      "source_node_id": "capture_frame",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-model-summary-metrics",
      "source_node_id": "segment",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-filter-summary-metrics",
      "source_node_id": "filter_regions",
      "source_port": "summary",
