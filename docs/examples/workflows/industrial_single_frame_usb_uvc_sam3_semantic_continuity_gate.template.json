    }
  ],
  "template_inputs": [
    {
      "input_id": "request_camera_config",
      "display_name": "Request Camera Config",
      "payload_type_id": "value.v1",
      "target_node_id": "request_camera_config_input",
      "target_port": "payload"
    },
    {
      "input_id": "request_prompts",
      "display_name": "Request Prompts",
      "payload_type_id": "text-prompts.v1",
      "target_node_id": "segment",
      "target_port": "prompts"
    },
    {
      "input_id": "request_roi",
      "display_name": "Request ROI",
      "payload_type_id": "value.v1",
      "target_node_id": "create_roi",
      "target_port": "value",
      "required": false
    }
  ],
  "template_outputs": [
    {
      "output_id": "captured_image",
      "display_name": "Captured Image",
      "payload_type_id": "image-ref.v1",
      "source_node_id": "capture_frame",
      "source_port": "image"
    },
    {
      "output_id": "capture_summary",
      "display_name": "Capture Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "capture_frame",
      "source_port": "summary"
    },
    {
      "output_id": "model_regions",
      "display_name": "Model Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "segment",
      "source_port": "regions"
    },
    {
      "output_id": "filtered_regions",
      "display_name": "Filtered Regions",
      "payload_type_id": "regions.v1",
      "source_node_id": "filter_regions",
      "source_port": "regions"
    },
    {
      "output_id": "effective_roi",
      "display_name": "Effective ROI",
      "payload_type_id": "roi.v1",
      "source_node_id": "create_roi",
      "source_port": "roi"
    },
    {
      "output_id": "review_overlay_image",
      "display_name": "Review Overlay Image",
      "payload_type_id": "image-ref.v1",
      "source_node_id": "overlay_regions",
      "source_port": "image"
    },
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "inspection_alarm",
      "display_name": "Inspection Alarm",
      "payload_type_id": "alarm-record.v1",
      "source_node_id": "alarm_condition",
      "source_port": "alarm"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    },
    {
      "output_id": "json_summary",
      "display_name": "JSON Save Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_result_json",
      "source_port": "summary"
    },
    {
      "output_id": "csv_summary",
      "display_name": "CSV Append Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "append_result_csv",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-usb-uvc-sam3-semantic-continuity-gate",
    "focus": "single-frame-industrial-camera-segmentation-rule-chain",
    "transport": "usb-uvc",
    "dynamic_roi_input_binding": "request_roi",
    "node_groups": {
      "input": [
        "request_camera_config_input"
      ],
      "capture": [
        "capture_frame"
      ],
      "model_and_filter": [
        "segment",
        "filter_regions"
      ],
      "roi_and_overlay": [
        "create_roi",
        "draw_roi",
        "overlay_regions"
      ],
      "rules": [
        "area_ratio",
        "continuity_score",
        "gap_check",
        "presence_check",
        "coverage_check",
        "area_ratio_check",
        "metadata_object",
        "metrics_object",
        "process_decision",
        "alarm_condition"
      ],
      "output": [
        "save_result_json",
        "append_result_csv"
      ]
    }
  }
}
