      "target_port": "values"
    },
    {
      "edge_id": "edge-gap-check-metrics",
      "source_node_id": "gap_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-coverage-metrics-object",
      "source_node_id": "coverage_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-metrics-object",
      "source_node_id": "presence_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-roi-summary-metrics-object",
      "source_node_id": "create_roi",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-presence-process",
      "source_node_id": "presence_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-area-ratio-check-process",
      "source_node_id": "area_ratio_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-coverage-process",
      "source_node_id": "coverage_check",
      "source_port": "result",
