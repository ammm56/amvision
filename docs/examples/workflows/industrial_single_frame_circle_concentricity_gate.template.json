{
  "format_id": "amvision.workflow-graph-template.v1",
  "template_id": "industrial-single-frame-circle-concentricity-gate-template",
  "template_version": "1.0.0",
  "display_name": "Industrial Single Frame Circle Concentricity Gate",
  "description": "面向工业单帧量测现场的双圆样例。输入本地图像路径，提取双圆轮廓，量测孔径、同心度和圆度，最后输出 OK/NG、报警对象和本地归档摘要。",
  "nodes": [
    {
      "node_id": "request_image_path_input",
      "node_type_id": "core.io.template-input.value",
      "parameters": {}
    },
    {
      "node_id": "load_image",
      "node_type_id": "core.io.image-load-local",
      "parameters": {}
    },
    {
      "node_id": "otsu",
      "node_type_id": "custom.opencv.otsu-threshold",
      "parameters": {
        "threshold_type": "binary"
      }
    },
    {
      "node_id": "contour",
      "node_type_id": "custom.opencv.contour",
      "parameters": {
        "retrieval_mode": "tree",
        "min_area": 50.0
      }
    },
    {
      "node_id": "filter_contours",
      "node_type_id": "custom.opencv.contour-filter",
      "parameters": {
        "sort_by": "area",
        "descending": true,
        "limit": 2
      }
    },
    {
      "node_id": "fit_circles",
      "node_type_id": "custom.opencv.min-enclosing-circle",
      "parameters": {
        "sort_by": "radius",
        "descending": true
      }
    },
    {
      "node_id": "measure_diameter",
      "node_type_id": "custom.opencv.circle-diameter",
      "parameters": {
        "circle_strategy": "smallest",
        "output_metric": "diameter"
      }
    },
    {
      "node_id": "measure_concentricity",
      "node_type_id": "custom.opencv.concentricity-metrics",
      "parameters": {
        "circle_a_strategy": "largest",
        "circle_b_strategy": "smallest",
        "output_metric": "center_distance_pixels"
      }
    },
    {
      "node_id": "contours_to_regions",
      "node_type_id": "custom.opencv.contours-to-regions",
      "parameters": {
        "region_id_prefix": "circle",
        "class_name_default": "circle-contour"
      }
    },
    {
      "node_id": "circularity_check",
      "node_type_id": "core.vision.circularity-check",
      "parameters": {
        "match_mode": "all",
        "min_circularity": 0.82,
        "min_fill_ratio": 0.75
      }
    },
    {
      "node_id": "diameter_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "min_value": 30.0,
        "max_value": 42.0,
        "min_inclusive": true,
        "max_inclusive": true
      }
    },
    {
      "node_id": "concentricity_check",
      "node_type_id": "core.rule.range-check",
      "parameters": {
        "max_value": 2.0,
        "max_inclusive": true
      }
    },
    {
      "node_id": "metadata_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "image_path"
        ],
        "fields": {
          "inspection_kind": "circle-concentricity-gate",
          "station_id": "line-geometry-02"
        }
      }
    },
    {
      "node_id": "metrics_object",
      "node_type_id": "core.logic.object-create",
      "parameters": {
        "keys": [
          "diameter_summary",
          "concentricity_summary",
          "circularity_metrics"
        ]
      }
    },
    {
      "node_id": "process_decision",
      "node_type_id": "core.rule.process-decision",
      "parameters": {
        "mode": "all",
        "condition_names": [
          "diameter",
          "concentricity",
          "circularity"
        ],
        "ok_reason": "circle concentricity gate passed",
        "ng_reason": "circle concentricity gate failed"
      }
    },
    {
      "node_id": "alarm_condition",
      "node_type_id": "core.rule.alarm-condition",
      "parameters": {
        "trigger_when": "condition-false",
        "alarm_level": "warning",
        "alarm_code": "CIRCLE-CONCENTRICITY-NG",
        "alarm_message": "circle concentricity gate failed",
        "clear_message": "circle concentricity gate passed"
      }
    },
    {
      "node_id": "save_result_json",
      "node_type_id": "core.output.json-save-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/circle-concentricity/result-{timestamp}.json",
        "overwrite": true,
        "indent": 2
      }
    },
    {
      "node_id": "append_result_csv",
      "node_type_id": "core.output.csv-append-local",
      "parameters": {
        "local_path": "{workflow_app_result_dir}/circle-concentricity/history.csv"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "edge-request-image-path-load-image",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "load_image",
      "target_port": "path"
    },
    {
      "edge_id": "edge-request-image-path-metadata",
      "source_node_id": "request_image_path_input",
      "source_port": "value",
      "target_node_id": "metadata_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-load-image-otsu-circle",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "otsu",
      "target_port": "image"
    },
    {
      "edge_id": "edge-otsu-contour-circle",
      "source_node_id": "otsu",
      "source_port": "image",
      "target_node_id": "contour",
      "target_port": "image"
    },
    {
      "edge_id": "edge-contour-filter-circle",
      "source_node_id": "contour",
      "source_port": "contours",
      "target_node_id": "filter_contours",
      "target_port": "contours"
    },
    {
      "edge_id": "edge-filter-fit-circles",
      "source_node_id": "filter_contours",
      "source_port": "contours",
      "target_node_id": "fit_circles",
      "target_port": "contours"
    },
    {
      "edge_id": "edge-fit-circles-diameter",
      "source_node_id": "fit_circles",
      "source_port": "circles",
      "target_node_id": "measure_diameter",
      "target_port": "circles"
    },
    {
      "edge_id": "edge-fit-circles-concentricity",
      "source_node_id": "fit_circles",
      "source_port": "circles",
      "target_node_id": "measure_concentricity",
      "target_port": "circles"
    },
    {
      "edge_id": "edge-filter-contours-to-regions",
      "source_node_id": "filter_contours",
      "source_port": "contours",
      "target_node_id": "contours_to_regions",
      "target_port": "contours"
    },
    {
      "edge_id": "edge-load-image-regions-image",
      "source_node_id": "load_image",
      "source_port": "image",
      "target_node_id": "contours_to_regions",
      "target_port": "image"
    },
    {
      "edge_id": "edge-regions-circularity-check",
      "source_node_id": "contours_to_regions",
      "source_port": "regions",
      "target_node_id": "circularity_check",
      "target_port": "regions"
    },
    {
      "edge_id": "edge-diameter-check",
      "source_node_id": "measure_diameter",
      "source_port": "value",
      "target_node_id": "diameter_check",
      "target_port": "value"
    },
    {
      "edge_id": "edge-concentricity-check",
      "source_node_id": "measure_concentricity",
      "source_port": "value",
      "target_node_id": "concentricity_check",
      "target_port": "value"
    },
    {
      "edge_id": "edge-diameter-summary-metrics",
      "source_node_id": "measure_diameter",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-concentricity-summary-metrics",
      "source_node_id": "measure_concentricity",
      "source_port": "summary",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-circularity-metrics-object",
      "source_node_id": "circularity_check",
      "source_port": "metrics",
      "target_node_id": "metrics_object",
      "target_port": "values"
    },
    {
      "edge_id": "edge-diameter-process",
      "source_node_id": "diameter_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-concentricity-process",
      "source_node_id": "concentricity_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-circularity-process",
      "source_node_id": "circularity_check",
      "source_port": "result",
      "target_node_id": "process_decision",
      "target_port": "conditions"
    },
    {
      "edge_id": "edge-metrics-process",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-process",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "process_decision",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-ok-alarm",
      "source_node_id": "process_decision",
      "source_port": "ok",
      "target_node_id": "alarm_condition",
      "target_port": "condition"
    },
    {
      "edge_id": "edge-metrics-alarm",
      "source_node_id": "metrics_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metrics"
    },
    {
      "edge_id": "edge-metadata-alarm",
      "source_node_id": "metadata_object",
      "source_port": "value",
      "target_node_id": "alarm_condition",
      "target_port": "metadata"
    },
    {
      "edge_id": "edge-process-save-json",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "save_result_json",
      "target_port": "result"
    },
    {
      "edge_id": "edge-process-append-csv",
      "source_node_id": "process_decision",
      "source_port": "result",
      "target_node_id": "append_result_csv",
      "target_port": "result"
    }
  ],
  "template_inputs": [
    {
      "input_id": "request_image_path",
      "display_name": "Request Image Path",
      "payload_type_id": "value.v1",
      "target_node_id": "request_image_path_input",
      "target_port": "payload"
    }
  ],
  "template_outputs": [
    {
      "output_id": "inspection_result",
      "display_name": "Inspection Result",
      "payload_type_id": "result-record.v1",
      "source_node_id": "process_decision",
      "source_port": "result"
    },
    {
      "output_id": "inspection_alarm",
      "display_name": "Inspection Alarm",
      "payload_type_id": "alarm-record.v1",
      "source_node_id": "alarm_condition",
      "source_port": "alarm"
    },
    {
      "output_id": "decision_summary",
      "display_name": "Decision Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "process_decision",
      "source_port": "summary"
    },
    {
      "output_id": "json_summary",
      "display_name": "JSON Save Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "save_result_json",
      "source_port": "summary"
    },
    {
      "output_id": "csv_summary",
      "display_name": "CSV Append Summary",
      "payload_type_id": "value.v1",
      "source_node_id": "append_result_csv",
      "source_port": "summary"
    }
  ],
  "metadata": {
    "example_kind": "industrial-single-frame-circle-concentricity-gate",
    "focus": "single-frame-industrial-geometry-circle-chain",
    "node_groups": {
      "input": [
        "request_image_path_input",
        "load_image"
      ],
      "geometry_measurement": [
        "otsu",
        "contour",
        "filter_contours",
        "fit_circles",
        "measure_diameter",
        "measure_concentricity",
        "contours_to_regions",
        "circularity_check"
      ],
      "inspection_rules": [
        "diameter_check",
        "concentricity_check"
      ],
      "decision_and_alarm": [
        "metadata_object",
        "metrics_object",
        "process_decision",
        "alarm_condition"
      ],
      "output": [
        "save_result_json",
        "append_result_csv"
      ]
    }
  }
}
