    {
      "name": "Projects",
      "item": [
        {
          "name": "Bootstrap Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var payload = pm.response.json();",
                  "  if (payload.project_id) pm.collectionVariables.set('projectId', payload.project_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{projectId}}\",\n  \"display_name\": \"{{projectDisplayName}}\",\n  \"description\": \"{{projectDescription}}\",\n  \"metadata\": {\n    \"source\": \"postman-current-api\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/bootstrap",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "projects",
                "bootstrap"
              ]
            },
            "description": "初始化一个 Project 目录、最小 manifest 和工作区骨架。"
          },
          "response": []
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects?include_summary=true&offset=0&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "projects"
              ],
              "query": [
                {
                  "key": "include_summary",
                  "value": "true"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "列出当前主体可见的 Project 目录项，并内联 summary。"
          },
          "response": []
        },
        {
          "name": "Get Project Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/{{projectId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "projects",
                "{{projectId}}"
              ]
            },
            "description": "读取单个 Project 的目录信息和当前 summary。"
          },
          "response": []
        },
        {
          "name": "Get Project Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/projects/{{projectId}}/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "projects",
                "{{projectId}}",
                "summary"
              ]
            },
            "description": "读取当前 Project 的工作台聚合快照。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dataset Imports",
      "item": [
        {
          "name": "Create Dataset Import",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 202) {",
                  "  var payload = pm.response.json();",
                  "  pm.collectionVariables.set('datasetImportId', payload.dataset_import_id);",
                  "  pm.collectionVariables.set('sourceImportId', payload.dataset_import_id);",
                  "  if (payload.task_id) {",
                  "    pm.collectionVariables.set('taskId', payload.task_id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "project_id",
                  "value": "{{projectId}}",
                  "type": "text"
                },
                {
                  "key": "dataset_id",
                  "value": "{{datasetId}}",
                  "type": "text"
                },
                {
                  "key": "format_type",
                  "value": "{{formatType}}",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "task_type",
                  "value": "{{taskType}}",
                  "type": "text"
                },
                {
                  "key": "split_strategy",
                  "value": "{{splitStrategy}}",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "class_map_json",
                  "value": "{{classMapJson}}",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "package",
                  "type": "file",
                  "src": "{{datasetZipPath}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/datasets/imports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "datasets",
                "imports"
              ]
            },
            "description": "上传 zip 数据集压缩包，创建 DatasetImport 和关联 TaskRecord，并提交到本地队列。默认 format_type 保持关闭，等同前端 auto；需要显式格式时再启用 format_type 并填写。"
          },
          "response": []
        },
        {
          "name": "Get Dataset Import Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/datasets/imports/{{datasetImportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "datasets",
                "imports",
                "{{datasetImportId}}"
              ]
            },
            "description": "按 DatasetImport id 查询导入记录详情、校验报告和关联 DatasetVersion 摘要。"
          },
          "response": []
        },
        {
          "name": "List Dataset Imports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/datasets/{{datasetId}}/imports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "datasets",
                "{{datasetId}}",
                "imports"
              ]
            },
            "description": "按 Dataset id 列出当前数据集下的导入记录摘要。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var payload = pm.response.json();",
                  "  pm.collectionVariables.set('taskId', payload.task_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{projectId}}\",\n  \"task_kind\": \"{{taskKind}}\",\n  \"display_name\": \"manual task from postman\",\n  \"parent_task_id\": null,\n  \"task_spec\": {\n    \"dataset_id\": \"{{datasetId}}\"\n  },\n  \"resource_profile_id\": null,\n  \"worker_pool\": \"{{workerPool}}\",\n  \"metadata\": {\n    \"source_import_id\": \"{{sourceImportId}}\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ]
            },
            "description": "创建一条公开任务记录，用于验证 tasks API。"
          },
          "response": []
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?project_id={{projectId}}&limit=100",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ],
              "query": [
                {
                  "key": "project_id",
                  "value": "{{projectId}}"
                },
                {
                  "key": "limit",
                  "value": "100"
                },
                {
                  "key": "task_kind",
                  "value": "{{taskKind}}",
                  "disabled": true
                },
                {
                  "key": "state",
                  "value": "{{taskState}}",
                  "disabled": true
                },
                {
                  "key": "worker_pool",
                  "value": "{{workerPool}}",
                  "disabled": true
                },
                {
                  "key": "dataset_id",
                  "value": "{{datasetId}}",
                  "disabled": true
                },
                {
                  "key": "source_import_id",
                  "value": "{{sourceImportId}}",
                  "disabled": true
                }
              ]
            },
            "description": "按当前公开筛选字段查询任务列表。"
          },
          "response": []
        },
        {
          "name": "Get Task Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/{{taskId}}?include_events=false",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks",
                "{{taskId}}"
              ],
              "query": [
                {
                  "key": "include_events",
                  "value": "false"
                }
              ]
            },
            "description": "按 task_id 查询轻量任务详情。默认不带历史事件；如需完整事件流，可把 include_events 改成 true，或直接调用 List Task Events。"
          },
          "response": []
        },
        {
          "name": "List Task Events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/{{taskId}}/events?limit=100",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks",
                "{{taskId}}",
                "events"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "100"
                },
                {
                  "key": "event_type",
                  "value": "{{eventType}}",
                  "disabled": true
                },
                {
                  "key": "after_created_at",
                  "value": "{{afterCreatedAt}}",
                  "disabled": true
                }
              ]
            },
            "description": "按 task_id 查询事件列表，可选按 event_type 和 after_created_at 过滤。"
          },
          "response": []
        },
        {
          "name": "Cancel Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks/{{taskId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks",
                "{{taskId}}",
                "cancel"
              ]
            },
            "description": "取消一条尚未结束的任务。"
          },
          "response": []
        }
      ]
    }
  ],
