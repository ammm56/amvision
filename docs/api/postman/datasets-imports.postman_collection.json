    {
      "name": "Dataset Imports",
      "item": [
        {
          "name": "Create Dataset Import",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 202) {",
                  "  var payload = pm.response.json();",
                  "  pm.collectionVariables.set('datasetImportId', payload.dataset_import_id);",
                  "  pm.collectionVariables.set('sourceImportId', payload.dataset_import_id);",
                  "  if (payload.task_id) {",
                  "    pm.collectionVariables.set('taskId', payload.task_id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-amvision-principal-id",
                "value": "{{principalId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-project-ids",
                "value": "{{projectId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-scopes",
                "value": "datasets:write",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "project_id",
                  "value": "{{projectId}}",
                  "type": "text"
                },
                {
                  "key": "dataset_id",
                  "value": "{{datasetId}}",
                  "type": "text"
                },
                {
                  "key": "format_type",
                  "value": "{{formatType}}",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "task_type",
                  "value": "detection",
                  "type": "text"
                },
                {
                  "key": "split_strategy",
                  "value": "{{splitStrategy}}",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "class_map_json",
                  "value": "{{classMapJson}}",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "package",
                  "type": "file",
                  "src": "{{datasetZipPath}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/datasets/imports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "datasets",
                "imports"
              ]
            },
            "description": "上传 zip 数据集压缩包，创建 DatasetImport 和关联 TaskRecord，并提交到本地队列。"
          },
          "response": []
        },
        {
          "name": "Get Dataset Import Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-amvision-principal-id",
                "value": "{{principalId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-project-ids",
                "value": "{{projectId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-scopes",
                "value": "datasets:read",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/datasets/imports/{{datasetImportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "datasets",
                "imports",
                "{{datasetImportId}}"
              ]
            },
            "description": "按 DatasetImport id 查询导入记录详情、校验报告和关联 DatasetVersion 摘要。"
          },
          "response": []
        },
        {
          "name": "List Dataset Imports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-amvision-principal-id",
                "value": "{{principalId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-project-ids",
                "value": "{{projectId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-scopes",
                "value": "datasets:read",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/datasets/{{datasetId}}/imports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "datasets",
                "{{datasetId}}",
                "imports"
              ]
            },
            "description": "按 Dataset id 列出当前数据集下的导入记录摘要。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var payload = pm.response.json();",
                  "  pm.collectionVariables.set('taskId', payload.task_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-amvision-principal-id",
                "value": "{{principalId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-project-ids",
                "value": "{{projectId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-scopes",
                "value": "tasks:write",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_id\": \"{{projectId}}\",\n  \"task_kind\": \"{{taskKind}}\",\n  \"display_name\": \"manual task from postman\",\n  \"parent_task_id\": null,\n  \"task_spec\": {\n    \"dataset_id\": \"{{datasetId}}\"\n  },\n  \"resource_profile_id\": null,\n  \"worker_pool\": \"{{workerPool}}\",\n  \"metadata\": {\n    \"source_import_id\": \"{{sourceImportId}}\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ]
            },
            "description": "创建一条公开任务记录，用于验证 tasks API。"
          },
          "response": []
        },
        {
          "name": "List Tasks",
