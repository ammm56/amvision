{
  "info": {
    "_postman_id": "c7030895-5031-4181-8312-9c46ea3d2042",
    "name": "amvision workflow 05 opencv process save image",
    "description": "第五类正式 workflow 联调 collection，覆盖纯 OpenCV 图片处理、保存图片和默认 HTTP 返回，适合作为本地联调第一条 smoke。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "principalId",
      "value": "user-1"
    },
    {
      "key": "projectId",
      "value": "project-1"
    },
    {
      "key": "workflowRuntimeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create App Runtime",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  var payload = pm.response.json();",
              "  if (payload.workflow_runtime_id) {",
              "    pm.collectionVariables.set('workflowRuntimeId', payload.workflow_runtime_id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "x-amvision-principal-id",
            "value": "{{principalId}}",
            "type": "text"
          },
          {
            "key": "x-amvision-project-ids",
            "value": "{{projectId}}",
            "type": "text"
          },
          {
            "key": "x-amvision-scopes",
            "value": "workflows:read,workflows:write",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"project_id\": \"project-1\",\n  \"application_id\": \"opencv-process-save-image-app\",\n  \"execution_policy_id\": \"runtime-default-policy\",\n  \"display_name\": \"OpenCV Process Save Image Runtime\",\n  \"metadata\": {\n    \"example_kind\": \"opencv-process-save-image\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/workflows/app-runtimes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "workflows",
            "app-runtimes"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get App Runtime Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-amvision-principal-id",
            "value": "{{principalId}}",
            "type": "text"
          },
          {
            "key": "x-amvision-project-ids",
            "value": "{{projectId}}",
            "type": "text"
          },
          {
            "key": "x-amvision-scopes",
            "value": "workflows:read",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/workflows/app-runtimes/{{workflowRuntimeId}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "workflows",
            "app-runtimes",
            "{{workflowRuntimeId}}",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Invoke App Runtime",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "x-amvision-principal-id",
            "value": "{{principalId}}",
            "type": "text"
          },
          {
            "key": "x-amvision-project-ids",
            "value": "{{projectId}}",
            "type": "text"
          },
          {
            "key": "x-amvision-scopes",
            "value": "workflows:write",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"input_bindings\": {\n    \"request_image\": {\n      \"image_base64\": \"iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO5WZr8AAAAASUVORK5CYII=\",\n      \"media_type\": \"image/png\"\n    }\n  },\n  \"execution_metadata\": {\n    \"scenario\": \"opencv-process-save-image\",\n    \"trigger_source\": \"sync-api\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/workflows/app-runtimes/{{workflowRuntimeId}}/invoke",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "workflows",
            "app-runtimes",
            "{{workflowRuntimeId}}",
            "invoke"
          ]
        }
      },
      "response": []
    }
  ]
}