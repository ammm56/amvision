        "body": {
          "mode": "raw",
          "raw": "{\n  \"application\": {\n    \"format_id\": \"amvision.flow-application.v1\",\n    \"application_id\": \"opencv-process-save-image-zeromq-app\",\n    \"display_name\": \"OpenCV Process Save Image ZeroMQ App\",\n    \"description\": \"同一个 workflow app 同时接收 HTTP image-base64 和 TriggerSource image-ref；图内显式把 image-ref 转成 image-base64 后复用已有 OpenCV 处理链路。\",\n    \"template_ref\": {\n      \"template_id\": \"opencv-process-save-image-zeromq-template\",\n      \"template_version\": \"1.0.0\",\n      \"source_kind\": \"json-file\",\n      \"source_uri\": \"docs/examples/workflows/opencv_process_save_image_zeromq.template.json\"\n    },\n    \"bindings\": [\n      {\n        \"binding_id\": \"request_image_base64\",\n        \"direction\": \"input\",\n        \"template_port_id\": \"request_image_base64\",\n        \"binding_kind\": \"api-request\",\n        \"required\": false,\n        \"config\": {\n          \"route\": \"/api/v1/workflow-apps/opencv/process-save-image-dual-input\",\n          \"method\": \"POST\"\n        },\n        \"metadata\": {\n          \"payload_type_id\": \"image-base64.v1\",\n          \"trigger_kind\": \"http-api\"\n        }\n      },\n      {\n        \"binding_id\": \"request_image_ref\",\n        \"direction\": \"input\",\n        \"template_port_id\": \"request_image_ref\",\n        \"binding_kind\": \"trigger-source-input\",\n        \"required\": false,\n        \"config\": {\n          \"payload_type_id\": \"image-ref.v1\",\n          \"content_type\": \"application/json\"\n        },\n        \"metadata\": {\n          \"payload_type_id\": \"image-ref.v1\",\n          \"trigger_kind\": \"zeromq-topic\"\n        }\n      },\n      {\n        \"binding_id\": \"http_response\",\n        \"direction\": \"output\",\n        \"template_port_id\": \"http_response\",\n        \"binding_kind\": \"http-response\",\n        \"config\": {\n          \"status_code\": 200\n        },\n        \"metadata\": {\n          \"payload_type_id\": \"http-response.v1\"\n        }\n      }\n    ],\n    \"runtime_mode\": \"python-json-workflow\",\n    \"metadata\": {\n      \"example_kind\": \"opencv-process-save-image-zeromq\",\n      \"intended_saved_object_key\": \"workflows/projects/{project_id}/applications/opencv-process-save-image-zeromq-app/application.json\",\n      \"trigger_source_input\": \"zeromq\",\n      \"http_input_binding\": \"request_image_base64\",\n      \"trigger_source_input_binding\": \"request_image_ref\"\n    }\n  }\n}",
          "options": {
