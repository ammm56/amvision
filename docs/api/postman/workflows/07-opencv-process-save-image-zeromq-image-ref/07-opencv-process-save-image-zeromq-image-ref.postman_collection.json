            "1.0.0"
          ]
        },
        "description": "保存 opencv_process_save_image_zeromq 的 workflow template。",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"template\": {\n    \"format_id\": \"amvision.workflow-graph-template.v1\",\n    \"template_id\": \"opencv-process-save-image-zeromq-template\",\n    \"template_version\": \"1.0.0\",\n    \"display_name\": \"OpenCV Process Save Image ZeroMQ Template\",\n    \"description\": \"同时接收 HTTP image-base64 和 TriggerSource image-ref 图片；图内显式把 image-ref 转成 image-base64 后复用既有 OpenCV 处理链路。\",\n    \"nodes\": [\n      {\n        \"node_id\": \"encode_request_image_ref\",\n        \"node_type_id\": \"core.io.image-base64-encode\",\n        \"parameters\": {}\n      },\n      {\n        \"node_id\": \"resolve_request_image\",\n        \"node_type_id\": \"core.logic.image-base64-coalesce\",\n        \"parameters\": {}\n      },\n      {\n        \"node_id\": \"decode_request_image\",\n        \"node_type_id\": \"core.io.image-base64-decode\",\n        \"parameters\": {}\n      },\n      {\n        \"node_id\": \"blur_image\",\n        \"node_type_id\": \"custom.opencv.gaussian-blur\",\n        \"parameters\": {\n          \"kernel_size\": 5,\n          \"sigma_x\": 1.2\n        }\n      },\n      {\n        \"node_id\": \"threshold_image\",\n        \"node_type_id\": \"custom.opencv.binary-threshold\",\n        \"parameters\": {\n          \"threshold\": 96,\n          \"max_value\": 255\n        }\n      },\n      {\n        \"node_id\": \"edge_image\",\n        \"node_type_id\": \"custom.opencv.canny\",\n        \"parameters\": {\n          \"threshold1\": 60,\n          \"threshold2\": 160,\n          \"aperture_size\": 3,\n          \"l2_gradient\": false\n        }\n      },\n      {\n        \"node_id\": \"save_image\",\n        \"node_type_id\": \"core.io.image-save\",\n        \"parameters\": {\n          \"object_key\": \"workflow-apps/opencv-process-save-image-zeromq/{workflow_run_id}/{timestamp}.png\",\n          \"overwrite\": false\n        }\n      },\n      {\n        \"node_id\": \"preview_image\",\n        \"node_type_id\": \"core.io.image-preview\",\n        \"parameters\": {\n          \"title\": \"Saved Edge Image\",\n          \"response_transport_mode\": \"storage-ref\"\n        }\n      },\n      {\n        \"node_id\": \"response\",\n        \"node_type_id\": \"core.output.http-response\",\n        \"parameters\": {\n          \"status_code\": 200\n        }\n      }\n    ],\n    \"edges\": [\n      {\n        \"edge_id\": \"edge-encode-request-image-ref\",\n        \"source_node_id\": \"encode_request_image_ref\",\n        \"source_port\": \"payload\",\n        \"target_node_id\": \"resolve_request_image\",\n        \"target_port\": \"fallback\"\n      },\n      {\n        \"edge_id\": \"edge-resolve-request-image\",\n        \"source_node_id\": \"resolve_request_image\",\n        \"source_port\": \"payload\",\n        \"target_node_id\": \"decode_request_image\",\n        \"target_port\": \"payload\"\n      },\n      {\n        \"edge_id\": \"edge-input-blur\",\n        \"source_node_id\": \"decode_request_image\",\n        \"source_port\": \"image\",\n        \"target_node_id\": \"blur_image\",\n        \"target_port\": \"image\"\n      },\n      {\n        \"edge_id\": \"edge-blur-threshold\",\n        \"source_node_id\": \"blur_image\",\n        \"source_port\": \"image\",\n        \"target_node_id\": \"threshold_image\",\n        \"target_port\": \"image\"\n      },\n      {\n        \"edge_id\": \"edge-threshold-canny\",\n        \"source_node_id\": \"threshold_image\",\n        \"source_port\": \"image\",\n        \"target_node_id\": \"edge_image\",\n        \"target_port\": \"image\"\n      },\n      {\n        \"edge_id\": \"edge-canny-save\",\n        \"source_node_id\": \"edge_image\",\n        \"source_port\": \"image\",\n        \"target_node_id\": \"save_image\",\n        \"target_port\": \"image\"\n      },\n      {\n        \"edge_id\": \"edge-save-preview\",\n        \"source_node_id\": \"save_image\",\n        \"source_port\": \"image\",\n        \"target_node_id\": \"preview_image\",\n        \"target_port\": \"image\"\n      },\n      {\n        \"edge_id\": \"edge-preview-response\",\n        \"source_node_id\": \"preview_image\",\n        \"source_port\": \"body\",\n        \"target_node_id\": \"response\",\n        \"target_port\": \"body\"\n      }\n    ],\n    \"template_inputs\": [\n      {\n        \"input_id\": \"request_image_base64\",\n        \"display_name\": \"Request Image Base64\",\n        \"payload_type_id\": \"image-base64.v1\",\n        \"target_node_id\": \"resolve_request_image\",\n        \"target_port\": \"primary\",\n        \"required\": false\n      },\n      {\n        \"input_id\": \"request_image_ref\",\n        \"display_name\": \"Request Image Ref\",\n        \"payload_type_id\": \"image-ref.v1\",\n        \"target_node_id\": \"encode_request_image_ref\",\n        \"target_port\": \"image\",\n        \"required\": false\n      }\n    ],\n    \"template_outputs\": [\n      {\n        \"output_id\": \"http_response\",\n        \"display_name\": \"HTTP Response\",\n        \"payload_type_id\": \"http-response.v1\",\n        \"source_node_id\": \"response\",\n        \"source_port\": \"response\"\n      }\n    ],\n    \"metadata\": {\n      \"example_kind\": \"opencv-process-save-image-zeromq\",\n      \"node_groups\": {\n        \"input\": [\n          \"encode_request_image_ref\",\n          \"resolve_request_image\",\n          \"decode_request_image\"\n        ],\n        \"opencv_process\": [\n          \"blur_image\",\n          \"threshold_image\",\n          \"edge_image\"\n        ],\n        \"output\": [\n          \"save_image\",\n          \"preview_image\",\n          \"response\"\n        ]\n      },\n      \"trigger_source_input\": \"zeromq\",\n      \"http_input_binding\": \"request_image_base64\",\n      \"trigger_source_input_binding\": \"request_image_ref\"\n    }\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
