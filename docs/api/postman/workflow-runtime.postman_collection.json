    {
      "name": "Workflow Prerequisites",
      "item": [
        {
          "name": "Save Workflow Template",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-amvision-principal-id",
                "value": "{{principalId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-project-ids",
                "value": "{{projectId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-scopes",
                "value": "workflows:read,workflows:write",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"template\": {\n    \"format_id\": \"amvision.workflow-graph-template.v1\",\n    \"template_id\": \"{{templateId}}\",\n    \"template_version\": \"{{templateVersion}}\",\n    \"display_name\": \"YOLOX Deployment Detection Lifecycle Real Path\",\n    \"description\": \"控制一个已有 sync deployment 资源，并在 backend-service 当前 deployment control plane 上按顺序执行 start、warmup、detection、health、stop。\",\n    \"nodes\": [\n      {\n        \"node_id\": \"start\",\n        \"node_type_id\": \"core.service.yolox-deployment.start\",\n        \"parameters\": {\n          \"deployment_instance_id\": \"{{deploymentInstanceId}}\",\n          \"runtime_mode\": \"sync\"\n        },\n        \"metadata\": {\n          \"sequence_index\": 1\n        }\n      },\n      {\n        \"node_id\": \"warmup\",\n        \"node_type_id\": \"core.service.yolox-deployment.warmup\",\n        \"parameters\": {\n          \"deployment_instance_id\": \"{{deploymentInstanceId}}\",\n          \"runtime_mode\": \"sync\"\n        },\n        \"metadata\": {\n          \"sequence_index\": 2\n        }\n      },\n      {\n        \"node_id\": \"detect\",\n        \"node_type_id\": \"core.model.yolox-detection\",\n        \"parameters\": {\n          \"deployment_instance_id\": \"{{deploymentInstanceId}}\",\n          \"auto_start_process\": false,\n          \"score_threshold\": 0.3,\n          \"save_result_image\": false,\n          \"return_preview_image_base64\": false\n        },\n        \"metadata\": {\n          \"sequence_index\": 3\n        }\n      },\n      {\n        \"node_id\": \"health\",\n        \"node_type_id\": \"core.service.yolox-deployment.health\",\n        \"parameters\": {\n          \"deployment_instance_id\": \"{{deploymentInstanceId}}\",\n          \"runtime_mode\": \"sync\"\n        },\n        \"metadata\": {\n          \"sequence_index\": 4\n        }\n      },\n      {\n        \"node_id\": \"stop\",\n        \"node_type_id\": \"core.service.yolox-deployment.stop\",\n        \"parameters\": {\n          \"deployment_instance_id\": \"{{deploymentInstanceId}}\",\n          \"runtime_mode\": \"sync\"\n        },\n        \"metadata\": {\n          \"sequence_index\": 5\n        }\n      }\n    ],\n    \"edges\": [],\n    \"template_inputs\": [\n      {\n        \"input_id\": \"request_image\",\n        \"display_name\": \"Request Image\",\n        \"payload_type_id\": \"image-ref.v1\",\n        \"target_node_id\": \"detect\",\n        \"target_port\": \"image\"\n      }\n    ],\n    \"template_outputs\": [\n      {\n        \"output_id\": \"start_body\",\n        \"display_name\": \"Start Body\",\n        \"payload_type_id\": \"response-body.v1\",\n        \"source_node_id\": \"start\",\n        \"source_port\": \"body\"\n      },\n      {\n        \"output_id\": \"warmup_body\",\n        \"display_name\": \"Warmup Body\",\n        \"payload_type_id\": \"response-body.v1\",\n        \"source_node_id\": \"warmup\",\n        \"source_port\": \"body\"\n      },\n      {\n        \"output_id\": \"detections\",\n        \"display_name\": \"Detections\",\n        \"payload_type_id\": \"detections.v1\",\n        \"source_node_id\": \"detect\",\n        \"source_port\": \"detections\"\n      },\n      {\n        \"output_id\": \"health_body\",\n        \"display_name\": \"Health Body\",\n        \"payload_type_id\": \"response-body.v1\",\n        \"source_node_id\": \"health\",\n        \"source_port\": \"body\"\n      },\n      {\n        \"output_id\": \"stop_body\",\n        \"display_name\": \"Stop Body\",\n        \"payload_type_id\": \"response-body.v1\",\n        \"source_node_id\": \"stop\",\n        \"source_port\": \"body\"\n      }\n    ],\n    \"metadata\": {\n      \"intended_saved_object_key\": \"workflows/projects/{{projectId}}/templates/{{templateId}}/versions/{{templateVersion}}/template.json\",\n      \"example_kind\": \"deployment-control-detection-lifecycle-real-path\",\n      \"deployment_instance_id_placeholder\": \"replace-with-existing-deployment-instance-id\",\n      \"uses_existing_deployment_instance\": true,\n      \"deployment_runtime_owner\": \"backend-service\",\n      \"node_groups\": {\n        \"deployment_control\": [\"start\", \"warmup\", \"health\", \"stop\"],\n        \"model_node\": [\"detect\"]\n      },\n      \"execution_order_note\": \"当前最小执行器会按 nodes 声明顺序稳定执行零入度节点，因此该示例通过节点声明顺序表达 start -> warmup -> detection -> health -> stop。\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/workflows/projects/{{projectId}}/templates/{{templateId}}/versions/{{templateVersion}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "workflows",
                "projects",
                "{{projectId}}",
                "templates",
                "{{templateId}}",
                "versions",
                "{{templateVersion}}"
              ]
            },
            "description": "保存 workflow template。请求体与 docs/api/examples/workflows/yolox_deployment_detection_lifecycle_real_path.save-template.request.json 对齐。"
          },
          "response": []
        },
        {
          "name": "Save Flow Application",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-amvision-principal-id",
                "value": "{{principalId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-project-ids",
                "value": "{{projectId}}",
                "type": "text"
              },
              {
                "key": "x-amvision-scopes",
                "value": "workflows:read,workflows:write",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application\": {\n    \"format_id\": \"amvision.flow-application.v1\",\n    \"application_id\": \"{{applicationId}}\",\n    \"display_name\": \"YOLOX Deployment Detection Lifecycle Real Path App\",\n    \"template_ref\": {\n      \"template_id\": \"{{templateId}}\",\n      \"template_version\": \"{{templateVersion}}\",\n      \"source_kind\": \"json-file\",\n      \"source_uri\": \"workflows/projects/{{projectId}}/templates/{{templateId}}/versions/{{templateVersion}}/template.json\",\n      \"metadata\": {}\n    },\n    \"runtime_mode\": \"python-json-workflow\",\n    \"description\": \"面向 Postman 手工调试的最小 FlowApplication 示例，控制并使用一个已有 deployment 资源，使用真实 workflow object key 路径。\",\n    \"bindings\": [\n      {\n        \"binding_id\": \"request_image\",\n        \"direction\": \"input\",\n        \"template_port_id\": \"request_image\",\n        \"binding_kind\": \"workflow-execute-input\",\n        \"config\": {\n          \"payload_type_id\": \"image-ref.v1\",\n          \"content_type\": \"image/*\"\n        },\n        \"metadata\": {}\n      },\n      {\n        \"binding_id\": \"start_body\",\n        \"direction\": \"output\",\n        \"template_port_id\": \"start_body\",\n        \"binding_kind\": \"workflow-execute-output\",\n        \"config\": {\n          \"payload_type_id\": \"response-body.v1\"\n        },\n        \"metadata\": {}\n      },\n      {\n        \"binding_id\": \"warmup_body\",\n        \"direction\": \"output\",\n        \"template_port_id\": \"warmup_body\",\n        \"binding_kind\": \"workflow-execute-output\",\n        \"config\": {\n          \"payload_type_id\": \"response-body.v1\"\n        },\n        \"metadata\": {}\n      },\n      {\n        \"binding_id\": \"detections\",\n        \"direction\": \"output\",\n        \"template_port_id\": \"detections\",\n        \"binding_kind\": \"workflow-execute-output\",\n        \"config\": {\n          \"payload_type_id\": \"detections.v1\"\n        },\n        \"metadata\": {}\n      },\n      {\n        \"binding_id\": \"health_body\",\n        \"direction\": \"output\",\n        \"template_port_id\": \"health_body\",\n        \"binding_kind\": \"workflow-execute-output\",\n        \"config\": {\n          \"payload_type_id\": \"response-body.v1\"\n        },\n        \"metadata\": {}\n      },\n      {\n        \"binding_id\": \"stop_body\",\n        \"direction\": \"output\",\n        \"template_port_id\": \"stop_body\",\n        \"binding_kind\": \"workflow-execute-output\",\n        \"config\": {\n          \"payload_type_id\": \"response-body.v1\"\n        },\n        \"metadata\": {}\n      }\n    ],\n    \"metadata\": {\n      \"intended_saved_object_key\": \"workflows/projects/{{projectId}}/applications/{{applicationId}}/application.json\",\n      \"example_kind\": \"deployment-control-detection-lifecycle-real-path\",\n      \"uses_existing_deployment_instance\": true,\n      \"deployment_instance_id_placeholder\": \"replace-with-existing-deployment-instance-id\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/workflows/projects/{{projectId}}/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "workflows",
                "projects",
                "{{projectId}}",
                "applications",
                "{{applicationId}}"
              ]
            },
            "description": "保存 FlowApplication。请求体与 docs/api/examples/workflows/yolox_deployment_detection_lifecycle_real_path.save-application.request.json 对齐。"
          },
          "response": []
        }
      ]
    },
