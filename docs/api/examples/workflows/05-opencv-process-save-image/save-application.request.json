{
  "application": {
    "format_id": "amvision.flow-application.v1",
    "application_id": "opencv-process-save-image-app",
    "display_name": "OpenCV Process Save Image App",
    "description": "接收 base64 图片，执行 OpenCV 处理并把结果保存到本地磁盘。",
    "template_ref": {
      "template_id": "opencv-process-save-image-template",
      "template_version": "1.0.0",
      "source_kind": "json-file",
      "source_uri": "docs/examples/workflows/opencv_process_save_image.template.json"
    },
    "bindings": [
      {
        "binding_id": "request_image",
        "direction": "input",
        "template_port_id": "request_image",
        "binding_kind": "api-request",
        "config": {
          "route": "/api/v1/workflow-apps/opencv/process-save-image",
          "method": "POST"
        },
        "metadata": {
          "payload_type_id": "image-base64.v1"
        }
      },
      {
        "binding_id": "http_response",
        "direction": "output",
        "template_port_id": "http_response",
        "binding_kind": "http-response",
        "config": {
          "status_code": 200
        },
        "metadata": {
          "payload_type_id": "http-response.v1"
        }
      }
    ],
    "runtime_mode": "python-json-workflow",
    "metadata": {
      "example_kind": "opencv-process-save-image",
      "intended_saved_object_key": "workflows/projects/{project_id}/applications/opencv-process-save-image-app/application.json"
    }
  }
}
