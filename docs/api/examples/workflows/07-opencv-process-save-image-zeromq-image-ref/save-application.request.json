{
  "application": {
    "format_id": "amvision.flow-application.v1",
    "application_id": "opencv-process-save-image-zeromq-app",
    "display_name": "OpenCV Process Save Image ZeroMQ App",
    "description": "同一个 workflow app 同时接收 HTTP image-base64 和 TriggerSource image-ref；图内显式把 image-ref 转成 image-base64 后复用已有 OpenCV 处理链路。",
    "template_ref": {
      "template_id": "opencv-process-save-image-zeromq-template",
      "template_version": "1.0.0",
      "source_kind": "json-file",
      "source_uri": "docs/examples/workflows/opencv_process_save_image_zeromq.template.json"
    },
    "bindings": [
      {
        "binding_id": "request_image_base64",
        "direction": "input",
        "template_port_id": "request_image_base64",
        "binding_kind": "api-request",
        "required": false,
        "config": {
          "route": "/api/v1/workflow-apps/opencv/process-save-image-dual-input",
          "method": "POST"
        },
        "metadata": {
          "payload_type_id": "image-base64.v1",
          "trigger_kind": "http-api"
        }
      },
      {
        "binding_id": "request_image_ref",
        "direction": "input",
        "template_port_id": "request_image_ref",
        "binding_kind": "trigger-source-input",
        "required": false,
        "config": {
          "payload_type_id": "image-ref.v1",
          "content_type": "application/json"
        },
        "metadata": {
          "payload_type_id": "image-ref.v1",
          "trigger_kind": "zeromq-topic"
        }
      },
      {
        "binding_id": "http_response",
        "direction": "output",
        "template_port_id": "http_response",
        "binding_kind": "http-response",
        "config": {
          "status_code": 200
        },
        "metadata": {
          "payload_type_id": "http-response.v1"
        }
      }
    ],
    "runtime_mode": "python-json-workflow",
    "metadata": {
      "example_kind": "opencv-process-save-image-zeromq",
      "intended_saved_object_key": "workflows/projects/{project_id}/applications/opencv-process-save-image-zeromq-app/application.json",
      "trigger_source_input": "zeromq",
      "http_input_binding": "request_image_base64",
      "trigger_source_input_binding": "request_image_ref"
    }
  }
}