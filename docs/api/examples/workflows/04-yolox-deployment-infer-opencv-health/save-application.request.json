{
  "application": {
    "format_id": "amvision.flow-application.v1",
    "application_id": "yolox-deployment-infer-opencv-health-app",
    "display_name": "YOLOX Deployment Infer OpenCV Health App",
    "description": "接收 base64 图片，调用已有 deployment 做同步推理，叠加检测框并返回 health 摘要。",
    "template_ref": {
      "template_id": "yolox-deployment-infer-opencv-health-template",
      "template_version": "1.0.0",
      "source_kind": "json-file",
      "source_uri": "docs/examples/workflows/yolox_deployment_infer_opencv_health.template.json"
    },
    "bindings": [
      {
        "binding_id": "request_image",
        "direction": "input",
        "template_port_id": "request_image",
        "binding_kind": "api-request",
        "config": {
          "route": "/api/v1/workflow-apps/yolox/deployment/infer-opencv-health",
          "method": "POST"
        },
        "metadata": {
          "payload_type_id": "image-base64.v1"
        }
      },
      {
        "binding_id": "deployment_request",
        "direction": "input",
        "template_port_id": "deployment_request",
        "binding_kind": "workflow-execute-input",
        "config": {
          "payload_type_id": "value.v1",
          "content_type": "application/json"
        },
        "metadata": {}
      },
      {
        "binding_id": "http_response",
        "direction": "output",
        "template_port_id": "http_response",
        "binding_kind": "http-response",
        "config": {
          "status_code": 200
        },
        "metadata": {
          "payload_type_id": "http-response.v1"
        }
      }
    ],
    "runtime_mode": "python-json-workflow",
    "metadata": {
      "example_kind": "deployment-infer-opencv-health",
      "uses_existing_deployment_instance": true,
      "intended_saved_object_key": "workflows/projects/{project_id}/applications/yolox-deployment-infer-opencv-health-app/application.json",
      "deployment_instance_id_binding": "deployment_request"
    }
  }
}
