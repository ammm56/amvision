      "parameter_schema": {
        "type": "object",
        "properties": {
          "model_scale": {
            "type": "string",
            "enum": [
              "nano",
              "tiny",
              "s",
              "m",
              "l",
              "x",
              "xx"
            ]
          },
          "device": {
            "type": "string"
          },
          "precision": {
            "type": "string",
            "enum": [
              "fp32",
              "fp16",
              "bf16"
            ]
          },
          "tracking_mode": {
            "type": "string",
            "title": "视频跟踪模式",
            "description": "shared 适合短窗口重复提示，stateful 适合上一帧 mask 延续，memory-prototype-state 适合作为默认中高强度模式，memory-attention-tracker 适合更长窗口、更大位移和复杂遮挡。",
            "enum": [
              "memory-prototype-state",
              "memory-attention-tracker",
              "stateful-mask-propagation",
              "shared-prompts-across-window"
            ],
            "default": "memory-prototype-state"
          },
          "history_limit": {
            "type": "integer",
            "title": "历史长度",
            "description": "memory-prototype-state 和 memory-attention-tracker 共用的跨帧历史长度。留空时默认按模式选择：memory-prototype-state=4，memory-attention-tracker=6。",
            "minimum": 1
          },
          "prototype_momentum": {
            "type": "number",
            "title": "原型动量",
            "description": "控制对象 prototype 的历史平滑程度。越大越稳定，越小越快跟随外观变化。",
            "minimum": 0,
            "maximum": 1,
            "default": 0.7
          },
          "attention_temperature": {
            "type": "number",
            "title": "注意力温度",
            "description": "仅 memory-attention-tracker 生效。越小越强调尖锐匹配，越大越平滑。",
            "exclusiveMinimum": 0,
            "default": 0.12
          },
          "prototype_blend_weight": {
            "type": "number",
            "title": "原型混合权重",
            "description": "仅 memory-attention-tracker 生效。控制 prototype 相似图对最终 memory prompt 的影响强度。",
            "minimum": 0,
            "maximum": 1,
            "default": 0.35
          },
          "max_memory_tokens_per_entry": {
            "type": "integer",
            "title": "单帧记忆 token 上限",
            "description": "仅 memory-attention-tracker 生效。单帧目标区域可保留的 memory token 数量上限。",
            "minimum": 1,
            "default": 256
          }
        }
      },
