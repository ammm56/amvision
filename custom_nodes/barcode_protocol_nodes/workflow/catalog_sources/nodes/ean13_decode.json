{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.barcode.ean13-decode",
  "display_name": "EAN-13 Decode",
  "category": "barcode.decode",
  "description": "从输入图片中解码 EAN-13 条码。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "results",
      "display_name": "Results",
      "payload_type_id": "barcode-results.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "try_rotate": {
        "type": "boolean"
      },
      "try_downscale": {
        "type": "boolean"
      },
      "try_invert": {
        "type": "boolean"
      },
      "is_pure": {
        "type": "boolean"
      },
      "return_errors": {
        "type": "boolean"
      },
      "text_mode": {
        "type": "string",
        "enum": [
          "plain",
          "hri",
          "escaped",
          "hex",
          "eci",
          "hex-eci"
        ]
      },
      "binarizer": {
        "type": "string",
        "enum": [
          "local-average",
          "global-histogram",
          "fixed-threshold",
          "bool-cast"
        ]
      },
      "ean_add_on_symbol": {
        "type": "string",
        "enum": [
          "ignore",
          "read",
          "require"
        ]
      }
    }
  },
  "capability_tags": [
    "barcode.decode",
    "barcode.ean13"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy",
      "zxing-cpp"
    ]
  },
  "node_pack_id": "barcode.protocol-nodes",
  "node_pack_version": "0.1.0",
  "metadata": {
    "family": "retail",
    "variant": "ean13",
    "scope_kind": "exact",
    "format_member_name": "EAN13"
  }
}
