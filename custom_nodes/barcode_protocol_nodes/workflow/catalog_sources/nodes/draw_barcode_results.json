{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.barcode.draw-results",
  "display_name": "Draw Barcode Results",
  "category": "barcode.render",
  "description": "把 barcode-results 中的 position 轮廓和文本叠加回原图，输出新的图片引用。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "results",
      "display_name": "Results",
      "payload_type_id": "barcode-results.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_thickness": {
        "type": "integer",
        "minimum": 1
      },
      "font_scale": {
        "type": "number",
        "minimum": 0
      },
      "draw_polygon": {
        "type": "boolean"
      },
      "draw_text": {
        "type": "boolean"
      },
      "draw_format": {
        "type": "boolean"
      },
      "draw_index": {
        "type": "boolean"
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "barcode.render",
    "barcode.draw"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "barcode.protocol-nodes",
  "node_pack_version": "0.1.0",
  "metadata": {
    "input_kind": "barcode-results.v1",
    "position_field": "position"
  }
}
