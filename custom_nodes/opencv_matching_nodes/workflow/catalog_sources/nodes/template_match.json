{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.template-match",
  "display_name": "Template Match",
  "category": "opencv.matching",
  "description": "在输入图片中按模板匹配搜索重复结构位置，并输出标准 regions.v1 与摘要，适合基准定位、标签找位和治具 presence 检查。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "template_image",
      "display_name": "Template Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "regions",
      "display_name": "Regions",
      "payload_type_id": "regions.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "method": {
        "type": "string",
        "enum": [
          "ccoeff-normed",
          "ccorr-normed",
          "sqdiff-normed"
        ],
        "default": "ccoeff-normed"
      },
      "score_threshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.8
      },
      "max_matches": {
        "type": "integer",
        "minimum": 1,
        "default": 1
      },
      "nms_iou_threshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.3
      },
      "convert_to_grayscale": {
        "type": "boolean",
        "default": true
      },
      "region_id_prefix": {
        "type": "string",
        "default": "tmpl"
      },
      "class_id_default": {
        "type": "integer",
        "default": -1
      },
      "class_name_default": {
        "type": "string",
        "default": "template-match"
      },
      "search_bbox_xyxy": {
        "type": "array",
        "title": "Search ROI",
        "description": "可选搜索区域 [x1, y1, x2, y2]；为空且未连接 ROI 时使用整张图。",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "number"
        }
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.template-match",
    "vision.localization",
    "vision.region",
    "inspection.position"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.matching-nodes",
  "node_pack_version": "0.1.0"
}
