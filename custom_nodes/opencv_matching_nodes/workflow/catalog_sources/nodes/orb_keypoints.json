{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.orb-keypoints",
  "display_name": "ORB Keypoints",
  "category": "opencv.matching",
  "description": "对输入图片提取 ORB 局部特征点与二进制描述，适合在模板匹配不稳、存在旋转缩放或局部视角变化时做参考对位前处理。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "features",
      "display_name": "Features",
      "payload_type_id": "local-features.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "max_features": {
        "type": "integer",
        "minimum": 1,
        "default": 500
      },
      "scale_factor": {
        "type": "number",
        "exclusiveMinimum": 1.0,
        "default": 1.2
      },
      "level_count": {
        "type": "integer",
        "minimum": 1,
        "default": 8
      },
      "edge_threshold": {
        "type": "integer",
        "minimum": 1,
        "default": 31
      },
      "first_level": {
        "type": "integer",
        "minimum": 0,
        "default": 0
      },
      "wta_k": {
        "type": "integer",
        "enum": [
          2,
          3,
          4
        ],
        "default": 2
      },
      "score_type": {
        "type": "string",
        "enum": [
          "harris",
          "fast"
        ],
        "default": "harris"
      },
      "patch_size": {
        "type": "integer",
        "minimum": 1,
        "default": 31
      },
      "fast_threshold": {
        "type": "integer",
        "minimum": 0,
        "default": 20
      },
      "use_roi_mask": {
        "type": "boolean",
        "default": true
      },
      "feature_id_prefix": {
        "type": "string",
        "default": "orb"
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.orb-keypoints",
    "vision.matching",
    "vision.feature"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.matching-nodes",
  "node_pack_version": "0.1.0"
}
