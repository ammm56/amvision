{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.rotation-correct",
  "display_name": "Rotation Correct",
  "category": "opencv.geometry",
  "description": "按给定角度或上游 value.v1 输入对图片做旋转矫正，并输出摘要，适合先把工件姿态收正再进入后续 ROI、量测和规则链。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "angle",
      "display_name": "Angle",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "angle_deg": {
        "type": "number"
      },
      "angle_path": {
        "type": "string"
      },
      "negate_angle": {
        "type": "boolean"
      },
      "expand_canvas": {
        "type": "boolean",
        "default": false
      },
      "interpolation": {
        "type": "string",
        "enum": [
          "nearest",
          "linear",
          "area",
          "cubic",
          "lanczos4"
        ],
        "default": "linear"
      },
      "border_mode": {
        "type": "string",
        "enum": [
          "constant",
          "replicate",
          "reflect",
          "reflect101",
          "wrap"
        ],
        "default": "constant"
      },
      "border_value": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255,
        "default": 0
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.rotation-correct",
    "vision.alignment",
    "inspection.pose"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.geometry-nodes",
  "node_pack_version": "0.1.0"
}
