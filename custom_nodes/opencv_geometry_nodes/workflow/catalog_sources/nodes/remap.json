{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.remap",
  "display_name": "Remap",
  "category": "opencv.geometry",
  "description": "按显式映射表执行像素级重映射，支持 map_xy 或 map_x/map_y，适合配合本地标定映射文件做展开、对位和固定几何校正。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "mapping",
      "display_name": "Mapping",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "mapping_path": {
        "type": "string"
      },
      "map_xy": {
        "type": "array"
      },
      "map_x": {
        "type": "array"
      },
      "map_y": {
        "type": "array"
      },
      "interpolation": {
        "type": "string",
        "enum": [
          "nearest",
          "linear",
          "area",
          "cubic",
          "lanczos4"
        ],
        "default": "linear"
      },
      "border_mode": {
        "type": "string",
        "enum": [
          "constant",
          "replicate",
          "reflect",
          "reflect101",
          "wrap"
        ],
        "default": "constant"
      },
      "border_value": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255,
        "default": 0
      },
      "output_object_key": {
        "type": "string"
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.remap",
    "vision.alignment",
    "inspection.calibration"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.geometry-nodes",
  "node_pack_version": "0.1.0"
}
