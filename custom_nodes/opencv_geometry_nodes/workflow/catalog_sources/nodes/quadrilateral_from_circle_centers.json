{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.quadrilateral-from-circle-centers",
  "display_name": "Quadrilateral From Circle Centers",
  "category": "opencv.geometry",
  "description": "从显式连接的 TL、TR、BR、BL 四个 circles.v1 输入构建凸四边形 ROI；不猜测角点语义。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {"name": "top_left", "display_name": "Top Left", "payload_type_id": "circles.v1"},
    {"name": "top_right", "display_name": "Top Right", "payload_type_id": "circles.v1"},
    {"name": "bottom_right", "display_name": "Bottom Right", "payload_type_id": "circles.v1"},
    {"name": "bottom_left", "display_name": "Bottom Left", "payload_type_id": "circles.v1"}
  ],
  "output_ports": [
    {"name": "roi", "display_name": "ROI", "payload_type_id": "roi.v1"},
    {"name": "summary", "display_name": "Summary", "payload_type_id": "value.v1"},
    {"name": "debug_preview", "display_name": "Debug Preview", "payload_type_id": "response-body.v1", "required": false}
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "top_left_index": {"type": "integer", "minimum": 1, "default": 1},
      "top_right_index": {"type": "integer", "minimum": 1, "default": 1},
      "bottom_right_index": {"type": "integer", "minimum": 1, "default": 1},
      "bottom_left_index": {"type": "integer", "minimum": 1, "default": 1},
      "min_width": {"type": "number", "exclusiveMinimum": 0, "default": 1},
      "min_height": {"type": "number", "exclusiveMinimum": 0, "default": 1},
      "left_outset": {"type": "number", "minimum": 0, "default": 0},
      "right_outset": {"type": "number", "minimum": 0, "default": 0},
      "top_outset": {"type": "number", "minimum": 0, "default": 0},
      "bottom_outset": {"type": "number", "minimum": 0, "default": 0},
      "roi_id": {"type": "string", "default": "circle-quadrilateral"},
      "display_name": {"type": "string", "default": "Circle Quadrilateral"},
      "debug_image_panel_enabled": {"type": "boolean", "default": false},
      "debug_image_panel_transport_mode": {
        "type": "string",
        "enum": ["storage-ref", "inline-base64"],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": ["opencv.geometry", "vision.roi", "vision.alignment"],
  "runtime_requirements": {"python_packages": ["opencv-python", "numpy"]},
  "node_pack_id": "opencv.geometry-nodes",
  "node_pack_version": "0.1.0"
}
