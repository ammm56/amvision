{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.affine-transform",
  "display_name": "Affine Transform",
  "category": "opencv.geometry",
  "description": "按 2x3 仿射矩阵或三对点关系对图片执行几何矫正，支持直接读取上游 value.v1 变换对象，适合平移、缩放、轻微旋转或剪切对位。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "transform",
      "display_name": "Transform",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "matrix_2x3": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "source_points": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          }
        }
      },
      "target_points": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          }
        }
      },
      "transform_path": {
        "type": "string"
      },
      "fit_output_bounds": {
        "type": "boolean",
        "default": false
      },
      "output_width": {
        "type": "integer",
        "minimum": 1
      },
      "output_height": {
        "type": "integer",
        "minimum": 1
      },
      "interpolation": {
        "type": "string",
        "enum": [
          "nearest",
          "linear",
          "area",
          "cubic",
          "lanczos4"
        ],
        "default": "linear"
      },
      "border_mode": {
        "type": "string",
        "enum": [
          "constant",
          "replicate",
          "reflect",
          "reflect101",
          "wrap"
        ],
        "default": "constant"
      },
      "border_value": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255,
        "default": 0
      },
      "output_object_key": {
        "type": "string"
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.affine-transform",
    "vision.alignment",
    "inspection.pose"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.geometry-nodes",
  "node_pack_version": "0.1.0"
}
