{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.line-deduplicate",
  "display_name": "Line Deduplicate",
  "category": "opencv.geometry",
  "description": "按角度、法向距离和线段投影重叠关系过滤重复直线；保持输入顺序并默认最多输出 10 条。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {"name": "lines", "display_name": "Lines", "payload_type_id": "lines.v1"}
  ],
  "output_ports": [
    {"name": "lines", "display_name": "Lines", "payload_type_id": "lines.v1"},
    {"name": "summary", "display_name": "Summary", "payload_type_id": "value.v1"}
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "angle_tolerance_deg": {"type": "number", "minimum": 0, "maximum": 90, "default": 2},
      "distance_tolerance_pixels": {"type": "number", "minimum": 0, "default": 4},
      "limit": {"type": "integer", "minimum": 1, "maximum": 1000, "default": 10}
    }
  },
  "capability_tags": ["opencv.geometry", "vision.lines", "vision.filter"],
  "runtime_requirements": {"python_packages": ["opencv-python", "numpy"]},
  "node_pack_id": "opencv.geometry-nodes",
  "node_pack_version": "0.1.0"
}
