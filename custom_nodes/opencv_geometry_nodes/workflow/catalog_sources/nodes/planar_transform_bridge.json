{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.planar-transform-bridge",
  "display_name": "Planar Transform Bridge",
  "category": "opencv.geometry",
  "description": "把 structured planar-transform.v1 显式桥接为图片 warp 和 ROI 投影输出，适合把 ORB/homography 结果继续接到参考帧校正、后续量测或 ROI 对位链。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "transform",
      "display_name": "Transform",
      "payload_type_id": "planar-transform.v1"
    },
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1",
      "required": false
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "direction": {
        "type": "string",
        "enum": [
          "source-a-to-source-b",
          "source-b-to-source-a"
        ],
        "default": "source-a-to-source-b"
      },
      "output_width": {
        "type": "integer",
        "minimum": 1
      },
      "output_height": {
        "type": "integer",
        "minimum": 1
      },
      "fit_output_bounds": {
        "type": "boolean",
        "default": false
      },
      "interpolation": {
        "type": "string",
        "enum": [
          "nearest",
          "linear",
          "area",
          "cubic",
          "lanczos4"
        ],
        "default": "linear"
      },
      "border_mode": {
        "type": "string",
        "enum": [
          "constant",
          "replicate",
          "reflect",
          "reflect101",
          "wrap"
        ],
        "default": "constant"
      },
      "border_value": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255,
        "default": 0
      },
      "output_object_key": {
        "type": "string"
      },
      "output_roi_id": {
        "type": "string"
      },
      "output_display_name": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.planar-transform-bridge",
    "vision.alignment",
    "vision.roi",
    "inspection.pose"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.geometry-nodes",
  "node_pack_version": "0.1.0"
}
