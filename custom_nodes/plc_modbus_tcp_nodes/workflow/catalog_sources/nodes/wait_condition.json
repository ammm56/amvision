{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.plc.modbus.wait-condition",
  "display_name": "Wait Modbus Condition",
  "category": "integration.plc",
  "description": "轮询 Modbus TCP 点位直到满足条件，直接按 00001 / 10001 / 30001 / 400001 这类地址语义等待现场点位放行。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "request",
      "display_name": "Request",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "result",
      "display_name": "Result",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "host": {
        "type": "string",
        "title": "Host"
      },
      "port": {
        "type": "integer",
        "title": "Port",
        "default": 502,
        "minimum": 1,
        "maximum": 65535
      },
      "unit_id": {
        "type": "integer",
        "title": "Unit ID",
        "default": 1,
        "minimum": 1,
        "maximum": 255
      },
      "timeout_seconds": {
        "type": "number",
        "title": "Request Timeout Seconds",
        "default": 3.0,
        "exclusiveMinimum": 0
      },
      "retries": {
        "type": "integer",
        "title": "Retries",
        "default": 1,
        "minimum": 0
      },
      "register_address": {
        "type": "string",
        "title": "Register Address",
        "examples": [
          "00001",
          "10001",
          "30001",
          "400001"
        ]
      },
      "data_type": {
        "type": "string",
        "title": "Data Type",
        "enum": [
          "bool",
          "uint8",
          "int8",
          "uint16",
          "int16",
          "uint32",
          "int32",
          "uint64",
          "int64",
          "float",
          "double",
          "string"
        ]
      },
      "word_order": {
        "type": "string",
        "title": "Word Order",
        "default": "big",
        "enum": [
          "big",
          "little"
        ]
      },
      "string_encoding": {
        "type": "string",
        "title": "String Encoding",
        "default": "utf-8"
      },
      "byte_position": {
        "type": "string",
        "title": "Byte Position",
        "default": "low",
        "enum": [
          "low",
          "high"
        ]
      },
      "string_length": {
        "type": "integer",
        "title": "String Length(Bytes)",
        "minimum": 1
      },
      "operator": {
        "type": "string",
        "title": "Operator",
        "default": "eq",
        "enum": [
          "eq",
          "ne",
          "gt",
          "ge",
          "lt",
          "le",
          "contains",
          "bitmask_any_set",
          "bitmask_all_set"
        ]
      },
      "expected_value": {
        "title": "Expected Value"
      },
      "poll_interval_ms": {
        "type": "integer",
        "title": "Poll Interval Milliseconds",
        "default": 200,
        "minimum": 1
      },
      "wait_timeout_seconds": {
        "type": [
          "number",
          "null"
        ],
        "title": "Wait Timeout Seconds",
        "description": "null 表示无限等待",
        "default": 60.0,
        "exclusiveMinimum": 0
      },
      "stable_match_count": {
        "type": "integer",
        "title": "Stable Match Count",
        "default": 1,
        "minimum": 1
      }
    },
    "required": [
      "host",
      "register_address",
      "data_type"
    ]
  },
  "capability_tags": [
    "integration.plc",
    "integration.modbus.wait-condition",
    "integration.trigger"
  ],
  "runtime_requirements": {
    "python_packages": []
  },
  "node_pack_id": "plc.modbus-tcp-nodes",
  "node_pack_version": "0.1.0"
}
