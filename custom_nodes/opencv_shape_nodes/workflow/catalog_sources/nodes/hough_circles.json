{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.hough-circles",
  "display_name": "Hough Circles",
  "category": "opencv.analysis",
  "description": "对输入图片执行 Hough 圆检测，并输出结构化 circles.v1。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "circles",
      "display_name": "Circles",
      "payload_type_id": "circles.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "dp": {
        "type": "number",
        "minimum": 0
      },
      "min_dist": {
        "type": "number",
        "minimum": 0
      },
      "param1": {
        "type": "number",
        "minimum": 0
      },
      "param2": {
        "type": "number",
        "minimum": 0
      },
      "min_radius": {
        "type": "integer",
        "minimum": 0
      },
      "max_radius": {
        "type": "integer",
        "minimum": 0
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "circle_index",
          "radius",
          "diameter",
          "area",
          "center_x",
          "center_y"
        ]
      },
      "descending": {
        "type": "boolean"
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.hough-circles",
    "vision.geometry",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
