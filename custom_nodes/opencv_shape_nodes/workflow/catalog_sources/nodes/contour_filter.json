{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.contour-filter",
  "display_name": "Contour Filter",
  "category": "opencv.shape",
  "description": "按面积、宽高、点数和排序规则筛选 contour 集合。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "min_area": {
        "type": "number",
        "minimum": 0
      },
      "max_area": {
        "type": "number",
        "minimum": 0
      },
      "min_width": {
        "type": "number",
        "minimum": 0
      },
      "max_width": {
        "type": "number",
        "minimum": 0
      },
      "min_height": {
        "type": "number",
        "minimum": 0
      },
      "max_height": {
        "type": "number",
        "minimum": 0
      },
      "min_point_count": {
        "type": "integer",
        "minimum": 0
      },
      "max_point_count": {
        "type": "integer",
        "minimum": 0
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "contour_index",
          "point_count",
          "area",
          "width",
          "height",
          "perimeter"
        ]
      },
      "descending": {
        "type": "boolean"
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.contour-filter",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
