{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.contour",
  "display_name": "Contour",
  "category": "opencv.shape",
  "description": "对输入图片提取 contour，并输出结构化 contour 集合。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "threshold": {
        "type": "integer",
        "title": "Threshold",
        "description": "普通 binary 模式下使用的阈值；Otsu 模式会由 OpenCV 自动求阈值。",
        "minimum": 0,
        "maximum": 255,
        "default": 127
      },
      "threshold_mode": {
        "type": "string",
        "title": "Threshold Mode",
        "description": "轮廓提取前的二值化方式。",
        "enum": [
          "binary",
          "binary-inverse",
          "otsu",
          "otsu-inverse"
        ],
        "default": "binary"
      },
      "retrieval_mode": {
        "type": "string",
        "title": "Retrieval Mode",
        "description": "OpenCV findContours 的轮廓层级检索方式。",
        "enum": [
          "external",
          "list",
          "tree",
          "ccomp"
        ],
        "default": "external"
      },
      "approximation": {
        "type": "string",
        "title": "Approximation",
        "description": "OpenCV findContours 的轮廓点近似方式。",
        "enum": [
          "simple",
          "none",
          "tc89-l1",
          "tc89-kcos"
        ],
        "default": "simple"
      },
      "min_area": {
        "type": "number",
        "title": "Min Area",
        "description": "小于该面积的 contour 会被过滤，单位为像素面积。",
        "minimum": 0,
        "default": 0
      },
      "max_area": {
        "type": "number",
        "title": "Max Area",
        "description": "大于该面积的 contour 会被过滤；为空表示不限制。",
        "minimum": 0
      },
      "min_width": {
        "type": "number",
        "title": "Min Width",
        "minimum": 0
      },
      "max_width": {
        "type": "number",
        "title": "Max Width",
        "minimum": 0
      },
      "min_height": {
        "type": "number",
        "title": "Min Height",
        "minimum": 0
      },
      "max_height": {
        "type": "number",
        "title": "Max Height",
        "minimum": 0
      },
      "min_aspect_ratio": {
        "type": "number",
        "title": "Min Aspect Ratio",
        "minimum": 0
      },
      "max_aspect_ratio": {
        "type": "number",
        "title": "Max Aspect Ratio",
        "minimum": 0
      },
      "min_rectangularity": {
        "type": "number",
        "title": "Min Rectangularity",
        "description": "contour 面积与外接 bbox 面积的最小比例。",
        "minimum": 0,
        "maximum": 1
      },
      "max_rectangularity": {
        "type": "number",
        "title": "Max Rectangularity",
        "description": "contour 面积与外接 bbox 面积的最大比例。",
        "minimum": 0,
        "maximum": 1
      },
      "max_contours": {
        "type": "integer",
        "title": "Max Contours",
        "description": "按面积从大到小稳定排序后最多输出的 contour 数量。",
        "minimum": 1,
        "maximum": 1000,
        "default": 10
      },
      "processing_max_long_edge": {
        "type": "integer",
        "title": "Processing Max Long Edge",
        "description": "算法处理图的最长边；大图会等比缩小，轮廓坐标和过滤尺寸自动还原到原图坐标。",
        "minimum": 256,
        "maximum": 32768,
        "default": 2048
      },
      "selected_contour_index": {
        "type": "integer",
        "minimum": 1,
        "title": "Selected Contour Index",
        "description": "可选点选 contour 序号；设置后只输出该 contour，便于在调试图上点选目标轮廓。"
      },
      "search_bbox_xyxy": {
        "type": "array",
        "title": "Search ROI",
        "description": "可选搜索区域 [x1, y1, x2, y2]；为空且未连接 ROI 时使用整张图。",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "number"
        }
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.contour",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
