{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.contour-to-roi",
  "display_name": "Contour To ROI",
  "category": "opencv.transform",
  "description": "把筛选后的 contour 转换为 roi.v1，适合接 Perspective Transform、Crop 和 ROI 规则节点。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "contour_index": {
        "type": "integer",
        "minimum": 0,
        "default": 0
      },
      "roi_kind": {
        "type": "string",
        "enum": [
          "polygon",
          "bbox"
        ],
        "default": "polygon"
      },
      "require_quad": {
        "type": "boolean",
        "default": true
      },
      "polygon_mode": {
        "type": "string",
        "enum": [
          "contour-points",
          "min-area-rect",
          "bbox"
        ],
        "default": "contour-points"
      },
      "roi_id_prefix": {
        "type": "string",
        "default": "contour-roi"
      },
      "display_name_prefix": {
        "type": "string",
        "default": "Contour ROI"
      }
    }
  },
  "capability_tags": [
    "opencv.contour-to-roi",
    "vision.roi",
    "vision.bridge",
    "vision.alignment"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
