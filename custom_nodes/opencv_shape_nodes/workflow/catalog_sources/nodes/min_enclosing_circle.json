{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.min-enclosing-circle",
  "display_name": "Min Enclosing Circle",
  "category": "opencv.shape",
  "description": "对 contour 集合计算最小外接圆，并输出结构化 circles.v1。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "circles",
      "display_name": "Circles",
      "payload_type_id": "circles.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "sort_by": {
        "type": "string",
        "enum": [
          "circle_index",
          "contour_index",
          "radius",
          "diameter",
          "area",
          "fill_ratio",
          "center_x",
          "center_y"
        ],
        "default": "radius"
      },
      "descending": {
        "type": "boolean",
        "default": true
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1000,
        "default": 10
      },
      "selected_contour_index": {
        "type": "integer",
        "minimum": 1,
        "title": "Selected Contour Index",
        "description": "可选点选 contour 序号；设置后只输出该 contour 对应的最小外接圆。"
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.min-enclosing-circle",
    "vision.geometry",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
