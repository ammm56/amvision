{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.contours-to-regions",
  "display_name": "Contours To Regions",
  "category": "opencv.transform",
  "description": "把 contours.v1 规整成标准 regions.v1，便于继续接工业规则和 ROI/连续性节点。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "regions",
      "display_name": "Regions",
      "payload_type_id": "regions.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "region_id_prefix": {
        "type": "string",
        "default": "ctr"
      },
      "class_id_default": {
        "type": "integer",
        "default": -1
      },
      "class_name_default": {
        "type": "string",
        "default": "contour"
      },
      "score_default": {
        "type": "number",
        "minimum": 0,
        "default": 1.0
      }
    }
  },
  "capability_tags": [
    "opencv.contours-to-regions",
    "vision.region",
    "vision.bridge"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
