{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.circle-measure",
  "display_name": "Circle Measure",
  "category": "opencv.shape",
  "description": "围绕参考圆径向采样亚像素边缘，使用 robust circle fitting 输出稳定圆定位和质量诊断。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    { "name": "image", "display_name": "Image", "payload_type_id": "image-ref.v1" },
    { "name": "roi", "display_name": "ROI", "payload_type_id": "roi.v1", "required": false }
  ],
  "output_ports": [
    { "name": "circles", "display_name": "Circles", "payload_type_id": "circles.v1" },
    { "name": "summary", "display_name": "Summary", "payload_type_id": "value.v1" },
    { "name": "debug_preview", "display_name": "Debug Preview", "payload_type_id": "response-body.v1", "required": false }
  ],
  "parameter_schema": {
    "type": "object",
    "required": ["reference_center_xy", "reference_radius_px"],
    "properties": {
      "reference_center_xy": {
        "type": "array",
        "title": "Reference Center",
        "description": "参考圆心原图坐标 [x, y]。",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "number" }
      },
      "reference_radius_px": { "type": "number", "exclusiveMinimum": 0, "title": "Reference Radius (px)" },
      "center_tolerance_px": { "type": "number", "exclusiveMinimum": 0, "default": 20, "title": "Center Tolerance (px)" },
      "radius_tolerance_px": { "type": "number", "exclusiveMinimum": 0, "default": 10, "title": "Radius Tolerance (px)" },
      "radial_sample_count": { "type": "integer", "minimum": 12, "maximum": 720, "default": 180, "title": "Radial Sample Count" },
      "gradient_threshold": { "type": "number", "minimum": 0, "default": 5, "title": "Gradient Threshold" },
      "edge_polarity": {
        "type": "string",
        "enum": ["any", "dark-to-bright", "bright-to-dark"],
        "default": "any",
        "title": "Edge Polarity"
      },
      "robust_loss": { "type": "string", "enum": ["huber", "tukey"], "default": "huber", "title": "Robust Loss" },
      "ransac_iterations": { "type": "integer", "minimum": 1, "maximum": 256, "default": 64, "title": "RANSAC Iterations" },
      "fit_inlier_threshold_px": { "type": "number", "exclusiveMinimum": 0, "default": 2, "title": "Fit Inlier Threshold (px)" },
      "minimum_arc_coverage": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5, "title": "Minimum Arc Coverage" },
      "maximum_fit_error_px": { "type": "number", "exclusiveMinimum": 0, "default": 2, "title": "Maximum Fit Error (px)" },
      "processing_max_long_edge_px": {
        "type": "integer",
        "minimum": 256,
        "maximum": 32768,
        "default": 2048,
        "title": "Processing Max Long Edge (px)",
        "description": "Search ROI 超过该尺寸时等比缩小，结果自动还原到原图坐标。"
      },
      "search_bbox_xyxy": {
        "type": "array",
        "title": "Search ROI",
        "description": "固定搜索区域 [x1, y1, x2, y2]；不会被 Reference Circle 或检测结果覆盖。",
        "minItems": 4,
        "maxItems": 4,
        "items": { "type": "number" }
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "enum": ["storage-ref", "inline-base64"],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": ["opencv.circle-measure", "vision.geometry", "vision.measurement"],
  "runtime_requirements": { "python_packages": ["opencv-python", "numpy"] },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
