{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.hough-lines",
  "display_name": "Hough Lines",
  "category": "opencv.shape",
  "description": "对输入图片执行概率 Hough 直线检测，并输出结构化 lines.v1。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "input_mode": {
        "type": "string",
        "enum": ["auto-canny", "binary-edge"],
        "default": "auto-canny",
        "title": "Input Mode",
        "description": "auto-canny 会先生成二值边缘；binary-edge 用于已连接 Canny 等边缘图。"
      },
      "canny_threshold1": {
        "type": "number",
        "minimum": 0,
        "maximum": 255,
        "default": 50,
        "title": "Canny Threshold 1"
      },
      "canny_threshold2": {
        "type": "number",
        "minimum": 0,
        "maximum": 255,
        "default": 150,
        "title": "Canny Threshold 2"
      },
      "rho_resolution": {
        "type": "number",
        "minimum": 0,
        "default": 1
      },
      "theta_step_deg": {
        "type": "number",
        "minimum": 0,
        "default": 1
      },
      "threshold": {
        "type": "integer",
        "minimum": 1,
        "default": 60
      },
      "min_line_length": {
        "type": "number",
        "minimum": 0,
        "default": 20
      },
      "max_line_gap": {
        "type": "number",
        "minimum": 0,
        "default": 5
      },
      "angle_min_deg": {
        "type": "number",
        "minimum": -90,
        "maximum": 90,
        "title": "Angle Min Deg",
        "description": "可选线段角度下限，角度范围为 -90 到 90；为空时不限制。"
      },
      "angle_max_deg": {
        "type": "number",
        "minimum": -90,
        "maximum": 90,
        "title": "Angle Max Deg",
        "description": "可选线段角度上限，角度范围为 -90 到 90；为空时不限制。"
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "line_index",
          "length_pixels",
          "angle_deg",
          "midpoint_x",
          "midpoint_y"
        ],
        "default": "length_pixels"
      },
      "descending": {
        "type": "boolean",
        "default": true
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1000,
        "default": 10,
        "title": "Result Limit"
      },
      "deduplicate": {
        "type": "boolean",
        "default": true,
        "title": "Deduplicate",
        "description": "按角度、法向距离和投影区间过滤同一物理直线的重复 Hough 片段。"
      },
      "deduplicate_angle_tolerance_deg": {
        "type": "number",
        "minimum": 0,
        "maximum": 45,
        "default": 2,
        "title": "Deduplicate Angle Tolerance Deg"
      },
      "deduplicate_distance_pixels": {
        "type": "number",
        "minimum": 0,
        "default": 8,
        "title": "Deduplicate Distance Pixels"
      },
      "processing_max_long_edge": {
        "type": "integer",
        "minimum": 256,
        "maximum": 32768,
        "default": 2048,
        "title": "Processing Max Long Edge",
        "description": "算法处理图的最长边；大图会等比缩小，结果坐标自动还原到原图。"
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      },
      "search_bbox_xyxy": {
        "type": "array",
        "title": "Search ROI",
        "description": "可选搜索区域 [x1, y1, x2, y2]；为空且未连接 ROI 时使用整张图。",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "number"
        }
      }
    }
  },
  "capability_tags": [
    "opencv.hough-lines",
    "vision.geometry",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
