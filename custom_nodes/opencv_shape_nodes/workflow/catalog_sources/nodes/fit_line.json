{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.fit-line",
  "display_name": "Fit Line",
  "category": "opencv.shape",
  "description": "对 contour 集合执行拟合直线，并输出结构化 lines.v1。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "distance_type": {
        "type": "string",
        "enum": [
          "l2",
          "l1",
          "l12",
          "fair",
          "welsch",
          "huber"
        ],
        "default": "l2"
      },
      "reps": {
        "type": "number",
        "minimum": 0,
        "default": 0.01
      },
      "aeps": {
        "type": "number",
        "minimum": 0,
        "default": 0.01
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "line_index",
          "contour_index",
          "length_pixels",
          "angle_deg",
          "midpoint_x",
          "midpoint_y"
        ],
        "default": "length_pixels"
      },
      "descending": {
        "type": "boolean",
        "default": true
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "description": "storage-ref 会保存为 Preview Run artifact；inline-base64 只适合小图快速调试。",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.fit-line",
    "vision.geometry",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.shape-nodes",
  "node_pack_version": "0.1.0"
}
