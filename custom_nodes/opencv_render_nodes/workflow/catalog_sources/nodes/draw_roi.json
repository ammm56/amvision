{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.draw-roi",
  "display_name": "Draw ROI",
  "category": "opencv.render",
  "description": "通过 OpenCV 把 roi.v1 直接绘制回原图，适合现场复核换型区域、检测范围和工位边界。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_thickness": {
        "type": "integer",
        "minimum": 1,
        "default": 2
      },
      "font_scale": {
        "type": "number",
        "minimum": 0,
        "default": 0.5
      },
      "fill_alpha": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.18
      },
      "draw_label": {
        "type": "boolean",
        "default": true
      },
      "draw_bbox": {
        "type": "boolean",
        "default": false
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.draw",
    "vision.render",
    "inspection.roi.visualize"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.render-nodes",
  "node_pack_version": "0.1.0"
}
