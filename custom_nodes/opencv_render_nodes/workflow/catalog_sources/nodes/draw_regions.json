{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.draw-regions",
  "display_name": "Draw Regions",
  "category": "opencv.render",
  "description": "通过 OpenCV 把 regions.v1 的 mask、polygon 和 bbox 绘制到图片上，适合模板匹配、分割和缺陷区域复核。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "regions",
      "display_name": "Regions",
      "payload_type_id": "regions.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "mask_alpha": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.35
      },
      "line_thickness": {
        "type": "integer",
        "minimum": 1,
        "default": 2
      },
      "font_scale": {
        "type": "number",
        "minimum": 0,
        "default": 0.5
      },
      "draw_masks": {
        "type": "boolean",
        "default": true
      },
      "draw_polygons": {
        "type": "boolean",
        "default": true
      },
      "draw_boxes": {
        "type": "boolean",
        "default": true
      },
      "draw_labels": {
        "type": "boolean",
        "default": true
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.draw-regions",
    "opencv.draw",
    "vision.render",
    "vision.region.debug"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.render-nodes",
  "node_pack_version": "0.1.0"
}
