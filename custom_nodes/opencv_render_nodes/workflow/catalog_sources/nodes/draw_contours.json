{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.draw-contours",
  "display_name": "Draw Contours",
  "category": "opencv.render",
  "description": "通过 OpenCV 把 contours.v1 结果绘制到图片上，适合轮廓调试和规则依据复核。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_thickness": {
        "type": "integer",
        "minimum": 1,
        "default": 2
      },
      "font_scale": {
        "type": "number",
        "minimum": 0,
        "default": 0.5
      },
      "draw_indices": {
        "type": "boolean",
        "default": true
      },
      "draw_bbox": {
        "type": "boolean",
        "default": false
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.draw",
    "vision.render",
    "vision.contour.debug"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.render-nodes",
  "node_pack_version": "0.1.0"
}
