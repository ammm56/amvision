{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.point-distance",
  "display_name": "Point Distance",
  "category": "opencv.measurement",
  "description": "计算两点之间的欧氏距离、曼哈顿距离和坐标差，适合中心距、孔距和装配偏移量测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "point_a",
      "display_name": "Point A",
      "payload_type_id": "value.v1"
    },
    {
      "name": "point_b",
      "display_name": "Point B",
      "payload_type_id": "value.v1"
    }
  ],
  "output_ports": [
    {
      "name": "value",
      "display_name": "Value",
      "payload_type_id": "value.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "output_metric": {
        "type": "string",
        "enum": [
          "distance_pixels",
          "manhattan_distance_pixels",
          "dx_pixels",
          "dy_pixels"
        ]
      }
    }
  },
  "capability_tags": [
    "opencv.measurement",
    "vision.geometry",
    "inspection.distance"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.measurement-nodes",
  "node_pack_version": "0.1.0"
}
