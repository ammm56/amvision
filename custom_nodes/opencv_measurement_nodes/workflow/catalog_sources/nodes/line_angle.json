{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.line-angle",
  "display_name": "Line Angle",
  "category": "opencv.measurement",
  "description": "读取选中直线的方向角或相对参考角度的偏差，适合做角度姿态和装配方向量测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    }
  ],
  "output_ports": [
    {
      "name": "value",
      "display_name": "Value",
      "payload_type_id": "value.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_strategy": {
        "type": "string",
        "enum": [
          "first",
          "longest",
          "shortest",
          "line-index"
        ]
      },
      "line_index": {
        "type": "integer",
        "minimum": 1
      },
      "reference_angle_deg": {
        "type": "number"
      },
      "output_metric": {
        "type": "string",
        "enum": [
          "angle_deg",
          "abs_angle_deg",
          "delta_angle_deg"
        ]
      }
    }
  },
  "capability_tags": [
    "opencv.measurement",
    "vision.geometry",
    "inspection.angle"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.measurement-nodes",
  "node_pack_version": "0.1.0"
}
