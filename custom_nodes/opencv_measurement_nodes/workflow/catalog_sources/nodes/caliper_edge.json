{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.caliper-edge",
  "display_name": "Caliper Edge",
  "category": "opencv.measurement",
  "description": "在轴向 ROI 或任意方向 Caliper 内搜索一个或多个边缘，支持极性、NMS 和亚像素位置。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "edge_orientation": {
        "type": "string",
        "enum": [
          "vertical",
          "horizontal"
        ],
        "default": "vertical"
      },
      "edge_polarity": {
        "type": "string",
        "enum": [
          "any",
          "dark-to-bright",
          "bright-to-dark"
        ],
        "default": "any"
      },
      "profile_reduction": {
        "type": "string",
        "enum": [
          "mean",
          "median",
          "max",
          "min"
        ],
        "default": "mean"
      },
      "smoothing_kernel_size": {
        "type": "integer",
        "minimum": 1,
        "default": 5
      },
      "gradient_threshold": {
        "type": "number",
        "minimum": 0,
        "default": 5.0
      },
      "line_xyxy": {
        "type": "array",
        "title": "Caliper Line",
        "description": "任意方向搜索线 [x1, y1, x2, y2]；设置后优先于轴向 ROI。",
        "minItems": 4,
        "maxItems": 4,
        "items": {"type": "number"}
      },
      "caliper_width": {
        "type": "number",
        "exclusiveMinimum": 0,
        "default": 20,
        "title": "Caliper Width"
      },
      "min_edge_distance": {
        "type": "number",
        "exclusiveMinimum": 0,
        "default": 10,
        "title": "Min Edge Distance"
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1000,
        "default": 10,
        "title": "Max Results"
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "enum": ["storage-ref", "inline-base64"],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.caliper",
    "vision.measurement",
    "vision.line",
    "inspection.edge"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.measurement-nodes",
  "node_pack_version": "0.1.0"
}
