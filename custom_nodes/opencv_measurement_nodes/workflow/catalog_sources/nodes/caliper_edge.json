{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.caliper-edge",
  "display_name": "Caliper Edge",
  "category": "opencv.measurement",
  "description": "在输入图片或 ROI 内按单轴 profile 搜索最强边缘，并输出单条结构化 lines.v1，适合台阶边、工件边和装配定位边的基准量测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "edge_orientation": {
        "type": "string",
        "enum": [
          "vertical",
          "horizontal"
        ],
        "default": "vertical"
      },
      "edge_polarity": {
        "type": "string",
        "enum": [
          "any",
          "dark-to-bright",
          "bright-to-dark"
        ],
        "default": "any"
      },
      "profile_reduction": {
        "type": "string",
        "enum": [
          "mean",
          "median",
          "max",
          "min"
        ],
        "default": "mean"
      },
      "smoothing_kernel_size": {
        "type": "integer",
        "minimum": 1,
        "default": 5
      },
      "gradient_threshold": {
        "type": "number",
        "minimum": 0,
        "default": 5.0
      }
    }
  },
  "capability_tags": [
    "opencv.caliper",
    "vision.measurement",
    "vision.line",
    "inspection.edge"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.measurement-nodes",
  "node_pack_version": "0.1.0"
}
