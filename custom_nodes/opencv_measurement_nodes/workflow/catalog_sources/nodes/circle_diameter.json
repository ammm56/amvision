{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.circle-diameter",
  "display_name": "Circle Diameter",
  "category": "opencv.measurement",
  "description": "读取选中圆的直径、半径、面积或周长，适合孔径、圆形工件和圆斑量测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "circles",
      "display_name": "Circles",
      "payload_type_id": "circles.v1"
    }
  ],
  "output_ports": [
    {
      "name": "value",
      "display_name": "Value",
      "payload_type_id": "value.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "circle_strategy": {
        "type": "string",
        "enum": [
          "first",
          "largest",
          "smallest",
          "circle-index"
        ]
      },
      "circle_index": {
        "type": "integer",
        "minimum": 1
      },
      "output_metric": {
        "type": "string",
        "enum": [
          "diameter",
          "radius",
          "area",
          "circumference"
        ]
      }
    }
  },
  "capability_tags": [
    "opencv.measurement",
    "vision.geometry",
    "inspection.diameter"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.measurement-nodes",
  "node_pack_version": "0.1.0"
}
