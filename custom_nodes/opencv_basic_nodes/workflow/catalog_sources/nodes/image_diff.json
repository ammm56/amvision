{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.image-diff",
  "display_name": "Image Diff",
  "category": "opencv.analysis",
  "description": "对当前图片和参考图片执行绝对差分，生成差异图和差异摘要。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "reference_image",
      "display_name": "Reference Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "diff_mode": {
        "type": "string",
        "enum": [
          "grayscale",
          "color"
        ]
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.image-diff",
    "vision.analysis",
    "vision.diff"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
