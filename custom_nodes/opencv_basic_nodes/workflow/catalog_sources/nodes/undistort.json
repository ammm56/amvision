{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.undistort",
  "display_name": "Undistort",
  "category": "opencv.geometry",
  "description": "按相机标定参数执行镜头畸变矫正，支持参数默认值或 value.v1 动态配置对象，适合先把桶形/枕形畸变收正再进入定位和量测链。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "config",
      "display_name": "Config",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "config_path": {
        "type": "string"
      },
      "camera_matrix": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "distortion_coefficients": {
        "type": "array",
        "items": {
          "type": "number"
        }
      },
      "rectify_matrix": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "new_camera_matrix": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "output_width": {
        "type": "integer",
        "minimum": 1
      },
      "output_height": {
        "type": "integer",
        "minimum": 1
      },
      "use_optimal_new_camera_matrix": {
        "type": "boolean",
        "default": true
      },
      "alpha": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0
      },
      "crop_to_valid_roi": {
        "type": "boolean",
        "default": false
      },
      "interpolation": {
        "type": "string",
        "enum": [
          "nearest",
          "linear",
          "area",
          "cubic",
          "lanczos4"
        ],
        "default": "linear"
      },
      "border_mode": {
        "type": "string",
        "enum": [
          "constant",
          "replicate",
          "reflect",
          "reflect101",
          "wrap"
        ],
        "default": "constant"
      },
      "border_value": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255,
        "default": 0
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.undistort",
    "vision.alignment",
    "inspection.calibration"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
