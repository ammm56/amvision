{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.crop",
  "display_name": "Crop",
  "category": "opencv.filter",
  "description": "按 ROI 或显式矩形参数裁剪输入图片，并输出裁剪摘要，适合先收紧工位窗口再进入后续差异、轮廓和量测规则链。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "x": {
        "type": "number"
      },
      "y": {
        "type": "number"
      },
      "width": {
        "type": "number",
        "exclusiveMinimum": 0
      },
      "height": {
        "type": "number",
        "exclusiveMinimum": 0
      },
      "padding": {
        "type": "integer",
        "minimum": 0,
        "default": 0
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.crop",
    "vision.preprocess",
    "inspection.roi"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
