{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.connected-components",
  "display_name": "Connected Components",
  "category": "opencv.analysis",
  "description": "把二值前景图分解成连通区域，并输出标准 regions.v1 与摘要。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "source_image",
      "display_name": "Source Image",
      "payload_type_id": "image-ref.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "regions",
      "display_name": "Regions",
      "payload_type_id": "regions.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "foreground_threshold": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      },
      "connectivity": {
        "type": "integer",
        "enum": [
          4,
          8
        ]
      },
      "min_area": {
        "type": "number",
        "minimum": 0
      },
      "max_area": {
        "type": "number",
        "minimum": 0
      },
      "max_components": {
        "type": "integer",
        "minimum": 1
      },
      "region_id_prefix": {
        "type": "string",
        "default": "cc"
      },
      "class_id_default": {
        "type": "integer",
        "default": -1
      },
      "class_name_default": {
        "type": "string",
        "default": "component"
      },
      "score_default": {
        "type": "number",
        "minimum": 0,
        "default": 1.0
      }
    }
  },
  "capability_tags": [
    "opencv.connected-components",
    "vision.analysis",
    "vision.region",
    "vision.diff"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
