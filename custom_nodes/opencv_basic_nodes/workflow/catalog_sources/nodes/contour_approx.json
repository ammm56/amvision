{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.contour-approx",
  "display_name": "Contour Approx",
  "category": "opencv.analysis",
  "description": "对 contour 集合执行多边形近似，适合把毛刺边界先规整成更稳定的工艺轮廓或多边形骨架。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "epsilon_mode": {
        "type": "string",
        "enum": [
          "perimeter-ratio",
          "pixels"
        ],
        "default": "perimeter-ratio"
      },
      "epsilon_value": {
        "type": "number",
        "minimum": 0
      },
      "closed": {
        "type": "boolean",
        "default": true
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "capability_tags": [
    "opencv.contour-approx",
    "vision.contour",
    "vision.shape"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
