{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.canny",
  "display_name": "Canny Edge",
  "category": "opencv.filter",
  "description": "对输入图片执行 Canny 边缘检测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "threshold1": {
        "type": "number",
        "minimum": 0,
        "maximum": 255
      },
      "threshold2": {
        "type": "number",
        "minimum": 0,
        "maximum": 255
      },
      "aperture_size": {
        "type": "integer",
        "minimum": 3,
        "maximum": 7
      },
      "l2_gradient": {
        "type": "boolean"
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.canny",
    "vision.filter"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}