{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.canny",
  "display_name": "Canny Edge",
  "category": "opencv.filter",
  "description": "对输入图片执行 Canny 边缘检测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "threshold1": {
        "type": "number",
        "minimum": 0,
        "maximum": 255,
        "default": 50
      },
      "threshold2": {
        "type": "number",
        "minimum": 0,
        "maximum": 255,
        "default": 150
      },
      "aperture_size": {
        "type": "integer",
        "minimum": 3,
        "maximum": 7,
        "default": 3
      },
      "l2_gradient": {
        "type": "boolean",
        "default": false
      },
      "pre_blur_kernel_size": {
        "type": "integer",
        "minimum": 1,
        "maximum": 31,
        "default": 3,
        "title": "Pre Blur Kernel Size",
        "description": "进入 Canny 前的 Gaussian Blur 奇数核；1 表示不平滑。"
      },
      "output_object_key": {
        "type": "string"
      },
      "search_bbox_xyxy": {
        "type": "array",
        "title": "Search ROI",
        "description": "可选搜索区域 [x1, y1, x2, y2]；区域外输出保持为 0。",
        "minItems": 4,
        "maxItems": 4,
        "items": {"type": "number"}
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "enum": ["storage-ref", "inline-base64"],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.canny",
    "vision.filter"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
