{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.bilateral-filter",
  "display_name": "Bilateral Filter",
  "category": "opencv.filter",
  "description": "对输入图片执行双边滤波，在平滑噪声的同时尽量保留边缘，适合纹理较弱但轮廓边界仍需保真的场景。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "roi",
      "display_name": "ROI",
      "payload_type_id": "roi.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    },
    {
      "name": "debug_preview",
      "display_name": "Debug Preview",
      "payload_type_id": "response-body.v1",
      "required": false
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "diameter": {
        "type": "integer",
        "minimum": 1,
        "default": 9
      },
      "sigma_color": {
        "type": "number",
        "minimum": 0,
        "default": 75.0
      },
      "sigma_space": {
        "type": "number",
        "minimum": 0,
        "default": 75.0
      },
      "output_object_key": {
        "type": "string"
      },
      "search_bbox_xyxy": {
        "type": "array",
        "title": "Processing ROI",
        "description": "可选处理区域 [x1, y1, x2, y2]；区域外保持原始 BGR24 像素不变。",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "number"
        }
      },
      "debug_image_panel_enabled": {
        "type": "boolean",
        "title": "显示调试图",
        "description": "仅编辑 Preview Run 使用；生产 runtime 默认不会生成调试图片。",
        "default": false
      },
      "debug_image_panel_transport_mode": {
        "type": "string",
        "title": "调试图返回方式",
        "enum": [
          "storage-ref",
          "inline-base64"
        ],
        "default": "storage-ref"
      }
    }
  },
  "capability_tags": [
    "opencv.bilateral-filter",
    "vision.preprocess",
    "inspection.edge-preserve"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
