{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.clahe",
  "display_name": "CLAHE",
  "category": "opencv.filter",
  "description": "对输入图片执行 CLAHE 局部对比度增强，适合光照不稳、局部对比不足或表面纹理偏弱的工业图像预处理。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "clip_limit": {
        "type": "number",
        "exclusiveMinimum": 0,
        "default": 2.0
      },
      "tile_grid_size": {
        "type": "integer",
        "minimum": 1,
        "default": 8
      },
      "apply_to_luminance": {
        "type": "boolean",
        "default": true
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.clahe",
    "vision.preprocess",
    "inspection.contrast"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
