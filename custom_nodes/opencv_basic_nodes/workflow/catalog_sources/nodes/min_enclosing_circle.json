{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.min-enclosing-circle",
  "display_name": "Min Enclosing Circle",
  "category": "opencv.analysis",
  "description": "对 contour 集合计算最小外接圆，并输出结构化 circles.v1。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "circles",
      "display_name": "Circles",
      "payload_type_id": "circles.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "sort_by": {
        "type": "string",
        "enum": [
          "circle_index",
          "contour_index",
          "radius",
          "diameter",
          "area",
          "fill_ratio",
          "center_x",
          "center_y"
        ]
      },
      "descending": {
        "type": "boolean"
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "capability_tags": [
    "opencv.min-enclosing-circle",
    "vision.geometry",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
