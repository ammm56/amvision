{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.convex-hull",
  "display_name": "Convex Hull",
  "category": "opencv.analysis",
  "description": "对 contour 集合计算凸包，适合先把凹陷、缺角或局部锯齿规整成更稳定的外形包络。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "sort_by": {
        "type": "string",
        "enum": [
          "contour_index",
          "contour_area",
          "hull_area",
          "solidity",
          "point_count"
        ]
      },
      "descending": {
        "type": "boolean"
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "capability_tags": [
    "opencv.convex-hull",
    "vision.contour",
    "vision.shape"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
