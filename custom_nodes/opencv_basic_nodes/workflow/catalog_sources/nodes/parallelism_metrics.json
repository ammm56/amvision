{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.parallelism-metrics",
  "display_name": "Parallelism Metrics",
  "category": "opencv.measurement",
  "description": "计算两条直线的角度差和相对偏移，适合导轨、边线和平行边装配检查。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    }
  ],
  "output_ports": [
    {
      "name": "value",
      "display_name": "Value",
      "payload_type_id": "value.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_a_strategy": {
        "type": "string",
        "enum": [
          "first",
          "longest",
          "shortest",
          "line-index"
        ]
      },
      "line_a_index": {
        "type": "integer",
        "minimum": 1
      },
      "line_b_strategy": {
        "type": "string",
        "enum": [
          "first",
          "longest",
          "shortest",
          "line-index"
        ]
      },
      "line_b_index": {
        "type": "integer",
        "minimum": 1
      },
      "output_metric": {
        "type": "string",
        "enum": [
          "delta_angle_deg",
          "abs_delta_angle_deg",
          "midpoint_offset_pixels",
          "mean_endpoint_offset_pixels"
        ]
      }
    }
  },
  "capability_tags": [
    "opencv.measurement",
    "vision.geometry",
    "inspection.parallelism"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
