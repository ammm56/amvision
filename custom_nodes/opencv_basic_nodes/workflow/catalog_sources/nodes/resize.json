{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.resize",
  "display_name": "Resize",
  "category": "opencv.filter",
  "description": "按目标宽高缩放输入图片；当仅提供一个边时按原始比例推导另一边。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "width": {
        "type": "integer",
        "minimum": 1
      },
      "height": {
        "type": "integer",
        "minimum": 1
      },
      "interpolation": {
        "type": "string",
        "enum": [
          "nearest",
          "linear",
          "area",
          "cubic",
          "lanczos4"
        ]
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.resize",
    "vision.filter"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
