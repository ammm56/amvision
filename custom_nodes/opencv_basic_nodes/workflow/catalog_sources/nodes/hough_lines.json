{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.hough-lines",
  "display_name": "Hough Lines",
  "category": "opencv.analysis",
  "description": "对输入图片执行概率 Hough 直线检测，并输出结构化 lines.v1。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "rho_resolution": {
        "type": "number",
        "minimum": 0
      },
      "theta_step_deg": {
        "type": "number",
        "minimum": 0
      },
      "threshold": {
        "type": "integer",
        "minimum": 1
      },
      "min_line_length": {
        "type": "number",
        "minimum": 0
      },
      "max_line_gap": {
        "type": "number",
        "minimum": 0
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "line_index",
          "length_pixels",
          "angle_deg",
          "midpoint_x",
          "midpoint_y"
        ]
      },
      "descending": {
        "type": "boolean"
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "capability_tags": [
    "opencv.hough-lines",
    "vision.geometry",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
