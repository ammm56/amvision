  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "alpha": {
        "type": "number",
        "default": 0.0
      },
      "beta": {
        "type": "number",
        "default": 255.0
      },
      "per_channel": {
        "type": "boolean",
        "default": false
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.normalize",
    "vision.preprocess"
  ],
  "runtime_requirements": {
