{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.draw-measurements",
  "display_name": "Draw Measurements",
  "category": "opencv.render",
  "description": "通过 OpenCV 把通用量测 summary 绘制到图片上，适合距离、偏移、槽宽和同心度依据复核。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "measurement",
      "display_name": "Measurement",
      "payload_type_id": "value.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_thickness": {
        "type": "integer",
        "minimum": 1,
        "default": 2
      },
      "point_radius": {
        "type": "integer",
        "minimum": 1,
        "default": 4
      },
      "font_scale": {
        "type": "number",
        "minimum": 0,
        "default": 0.5
      },
      "draw_labels": {
        "type": "boolean",
        "default": true
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.draw",
    "vision.render",
    "inspection.measurement.visualize"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
