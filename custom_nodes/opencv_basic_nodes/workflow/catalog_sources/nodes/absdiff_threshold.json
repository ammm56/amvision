{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.absdiff-threshold",
  "display_name": "Absdiff Threshold",
  "category": "opencv.filter",
  "description": "把差分图通过阈值化收成前景变化区域二值图。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "threshold": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      },
      "max_value": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      },
      "threshold_type": {
        "type": "string",
        "enum": [
          "binary",
          "binary-inv"
        ]
      },
      "output_object_key": {
        "type": "string"
      }
    }
  },
  "capability_tags": [
    "opencv.absdiff-threshold",
    "vision.filter",
    "vision.diff"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
