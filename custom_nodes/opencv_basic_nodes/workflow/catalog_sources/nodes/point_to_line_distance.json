{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.point-to-line-distance",
  "display_name": "Point To Line Distance",
  "category": "opencv.measurement",
  "description": "读取单个点到选中直线的距离，适合做中心点偏移、边缘偏移和装配位置量测。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "lines",
      "display_name": "Lines",
      "payload_type_id": "lines.v1"
    },
    {
      "name": "point",
      "display_name": "Point",
      "payload_type_id": "value.v1"
    }
  ],
  "output_ports": [
    {
      "name": "value",
      "display_name": "Value",
      "payload_type_id": "value.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "line_strategy": {
        "type": "string",
        "enum": [
          "first",
          "longest",
          "shortest",
          "line-index"
        ]
      },
      "line_index": {
        "type": "integer",
        "minimum": 1
      },
      "output_metric": {
        "type": "string",
        "enum": [
          "distance_pixels",
          "signed_distance_pixels"
        ]
      }
    }
  },
  "capability_tags": [
    "opencv.measurement",
    "vision.geometry",
    "inspection.offset"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
