{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.opencv.contour-filter",
  "display_name": "Contour Filter",
  "category": "opencv.analysis",
  "description": "按面积、宽高、点数和排序规则筛选 contour 集合。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    }
  ],
  "output_ports": [
    {
      "name": "contours",
      "display_name": "Contours",
      "payload_type_id": "contours.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "min_area": {
        "type": "number",
        "minimum": 0
      },
      "max_area": {
        "type": "number",
        "minimum": 0
      },
      "min_width": {
        "type": "number",
        "minimum": 0
      },
      "max_width": {
        "type": "number",
        "minimum": 0
      },
      "min_height": {
        "type": "number",
        "minimum": 0
      },
      "max_height": {
        "type": "number",
        "minimum": 0
      },
      "min_point_count": {
        "type": "integer",
        "minimum": 0
      },
      "max_point_count": {
        "type": "integer",
        "minimum": 0
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "contour_index",
          "point_count",
          "area",
          "width",
          "height",
          "perimeter"
        ]
      },
      "descending": {
        "type": "boolean"
      },
      "limit": {
        "type": "integer",
        "minimum": 1
      }
    }
  },
  "capability_tags": [
    "opencv.contour-filter",
    "vision.analysis"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "opencv.basic-nodes",
  "node_pack_version": "0.1.0"
}
