{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.camera.usb.capture-frame",
  "display_name": "Capture USB/UVC Frame",
  "category": "camera.usb",
  "description": "从指定 USB / UVC 相机读取单帧图片，输出标准 image-ref.v1 与结构化采集摘要，可直接接入检测、分割和工业规则链。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "request",
      "display_name": "Request",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "image",
      "display_name": "Image",
      "payload_type_id": "image-ref.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "device_index": {
        "type": "integer",
        "title": "Device Index",
        "default": 0,
        "minimum": 0
      },
      "device_path": {
        "type": "string",
        "title": "Device Path"
      },
      "backend_preference": {
        "type": "string",
        "title": "Backend Preference",
        "default": "any",
        "enum": [
          "any",
          "dshow",
          "msmf",
          "v4l2",
          "gstreamer"
        ]
      },
      "width": {
        "type": "integer",
        "title": "Width",
        "minimum": 1
      },
      "height": {
        "type": "integer",
        "title": "Height",
        "minimum": 1
      },
      "fps": {
        "type": "number",
        "title": "FPS",
        "exclusiveMinimum": 0
      },
      "warmup_frame_count": {
        "type": "integer",
        "title": "Warmup Frame Count",
        "default": 2,
        "minimum": 0
      },
      "retry_read_count": {
        "type": "integer",
        "title": "Retry Read Count",
        "default": 3,
        "minimum": 1
      },
      "output_format": {
        "type": "string",
        "title": "Output Format",
        "default": "png",
        "enum": [
          "png",
          "jpeg"
        ]
      },
      "jpeg_quality": {
        "type": "integer",
        "title": "JPEG Quality",
        "default": 95,
        "minimum": 1,
        "maximum": 100
      },
      "output_object_key": {
        "type": "string",
        "title": "Output Object Key"
      },
      "overwrite": {
        "type": "boolean",
        "title": "Overwrite",
        "default": true
      }
    }
  },
  "capability_tags": [
    "integration.camera",
    "integration.camera.usb-uvc",
    "vision.image.capture"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "camera.usb-uvc-nodes",
  "node_pack_version": "0.1.0",
  "metadata": {
    "phase": "implemented"
  }
}
