{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.camera.usb.read-window",
  "display_name": "Read USB/UVC Window",
  "category": "camera.usb",
  "description": "从已启动采流的 USB / UVC 相机会话缓冲中读取一段 frame-window.v1，供视频预览、时序分割和后续视频链复用。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "session",
      "display_name": "Session",
      "payload_type_id": "camera-session.v1"
    },
    {
      "name": "request",
      "display_name": "Request",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "session",
      "display_name": "Session",
      "payload_type_id": "camera-session.v1"
    },
    {
      "name": "frames",
      "display_name": "Frames",
      "payload_type_id": "frame-window.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "max_frames": {
        "type": "integer",
        "title": "Max Frames",
        "default": 8,
        "minimum": 1
      },
      "sample_mode": {
        "type": "string",
        "title": "Sample Mode",
        "default": "tail",
        "enum": [
          "tail",
          "head",
          "uniform"
        ]
      },
      "wait_for_min_frames": {
        "type": "integer",
        "title": "Wait For Min Frames",
        "default": 1,
        "minimum": 1
      },
      "wait_timeout_seconds": {
        "type": "number",
        "title": "Wait Timeout Seconds",
        "default": 1.0,
        "minimum": 0
      },
      "output_format": {
        "type": "string",
        "title": "Output Format",
        "default": "png",
        "enum": [
          "png",
          "jpeg"
        ]
      },
      "jpeg_quality": {
        "type": "integer",
        "title": "JPEG Quality",
        "default": 95,
        "minimum": 1,
        "maximum": 100
      }
    }
  },
  "capability_tags": [
    "integration.camera",
    "integration.camera.usb-uvc",
    "vision.video.window"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "camera.usb-uvc-nodes",
  "node_pack_version": "0.1.0",
  "metadata": {
    "phase": "implemented"
  }
}
