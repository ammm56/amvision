{
  "format_id": "amvision.node-definition.v1",
  "node_type_id": "custom.camera.usb.open-device",
  "display_name": "Open USB/UVC Device",
  "category": "camera.usb",
  "description": "打开一个可跨节点复用的 USB / UVC 相机会话，适合现场单帧重复采图和参数调整链路。",
  "implementation_kind": "custom-node",
  "runtime_kind": "python-callable",
  "input_ports": [
    {
      "name": "request",
      "display_name": "Request",
      "payload_type_id": "value.v1",
      "required": false
    }
  ],
  "output_ports": [
    {
      "name": "session",
      "display_name": "Session",
      "payload_type_id": "camera-session.v1"
    },
    {
      "name": "summary",
      "display_name": "Summary",
      "payload_type_id": "value.v1"
    }
  ],
  "parameter_schema": {
    "type": "object",
    "properties": {
      "device_index": {
        "type": "integer",
        "title": "Device Index",
        "default": 0,
        "minimum": 0
      },
      "device_path": {
        "type": "string",
        "title": "Device Path"
      },
      "backend_preference": {
        "type": "string",
        "title": "Backend Preference",
        "default": "any",
        "enum": [
          "any",
          "dshow",
          "msmf",
          "v4l2",
          "gstreamer"
        ]
      },
      "width": {
        "type": "integer",
        "title": "Width",
        "minimum": 1
      },
      "height": {
        "type": "integer",
        "title": "Height",
        "minimum": 1
      },
      "fps": {
        "type": "number",
        "title": "FPS",
        "exclusiveMinimum": 0
      },
      "probe_frame": {
        "type": "boolean",
        "title": "Probe Frame",
        "default": true
      },
      "warmup_frame_count": {
        "type": "integer",
        "title": "Warmup Frame Count",
        "default": 1,
        "minimum": 0
      },
      "retry_read_count": {
        "type": "integer",
        "title": "Retry Read Count",
        "default": 1,
        "minimum": 1
      }
    }
  },
  "capability_tags": [
    "integration.camera",
    "integration.camera.usb-uvc",
    "vision.device.session"
  ],
  "runtime_requirements": {
    "python_packages": [
      "opencv-python",
      "numpy"
    ]
  },
  "node_pack_id": "camera.usb-uvc-nodes",
  "node_pack_version": "0.1.0",
  "metadata": {
    "phase": "implemented"
  }
}
