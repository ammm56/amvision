{
  "name": "@amvision/web-ui",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5601",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 6601",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@vueuse/core": "^14.3.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.7",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.0"
  }
}
